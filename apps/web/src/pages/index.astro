---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Constellation from '../components/Constellation.astro';
import { REPO, SPEC } from '../site.ts';
---

<Base>
  <Nav />

  <main id="main">
    <!-- ===================== HERO — routing constellation (DESIGN.md §6/§8) ===================== -->
    <section class="hero" data-hero>
      <div class="container">
        <div class="hero__panel">
          <Constellation />

          <div class="hero__content">
            <Eyebrow text="Open best-execution layer · Canton" data-anim />

            <h1 class="hero__headline" data-anim>
              <span class="hero__line">Best execution,</span>
              <span class="hero__line hero__line--muted">native to Canton.</span
              >
            </h1>

            <p class="hero__sub" data-anim>
              Synfin aggregates quotes across every Canton venue, routes to the
              best price, and settles the split in one atomic transaction — with
              per-leg privacy.
            </p>

            <div class="hero__cta" data-anim>
              <Button
                variant="primary"
                href={SPEC}
                target="_blank"
                rel="noopener noreferrer">Read the spec ↗</Button
              >
              <Button
                variant="ghost"
                href={REPO}
                target="_blank"
                rel="noopener noreferrer">View on GitHub</Button
              >
            </div>
          </div>

          <div class="hero__band">
            <span class="hero__scroll mono">
              <span class="hero__scroll-ring" aria-hidden="true">↓</span>
              01 / 03 · SCROLL
            </span>
            <span class="hero__proof mono">
              <span class="hero__proof-dot" aria-hidden="true"></span>
              built on CIP-0056 / 0112 · 10/10 on-ledger tests
            </span>
          </div>
        </div>
      </div>
    </section>

    {/* TODO(Phase 2 — CONTENT.md §2): The problem (#problem) */}
    {/* TODO(Phase 2 — CONTENT.md §3): How it works (#how-it-works) */}
    {
      /* TODO(Phase 2 — CONTENT.md §4): Proof bento — RouterCard + +47.8 stat + privacy diagram (#proof) */
    }
    {/* TODO(Phase 2 — CONTENT.md §5): Per-leg privacy (#privacy) */}
    {/* TODO(Phase 2 — CONTENT.md §6): How venues plug in (#architecture) */}
    {/* TODO(Phase 2 — CONTENT.md §7): Open by design (#open) */}
    {/* TODO(Phase 2 — CONTENT.md §8): For the ecosystem (#ecosystem) */}
  </main>

  <Footer />
</Base>

<style>
  .hero {
    padding-top: 8px;
    padding-bottom: var(--section-y);
  }

  .hero__panel {
    position: relative;
    overflow: hidden;
    min-height: clamp(560px, 60vw, 768px);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--panel-radius);
    box-shadow: var(--card-inset), var(--card-shadow);
    display: grid;
    place-items: center;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 22px;
    max-width: 900px;
    padding: 40px var(--gutter);
  }

  .hero__headline {
    display: flex;
    flex-direction: column;
    font-size: clamp(34px, 7.4vw, 92px);
    line-height: 0.97;
    letter-spacing: -0.035em;
  }
  .hero__line {
    white-space: nowrap;
  }
  @media (max-width: 460px) {
    .hero__line {
      white-space: normal;
    }
  }
  .hero__line--muted {
    color: var(--ink-3);
  }

  .hero__sub {
    max-width: 600px;
    font-size: clamp(16px, 2.2vw, 19px);
    line-height: 1.5;
    color: var(--ink-2);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 6px;
  }

  /* Bottom band */
  .hero__band {
    position: absolute;
    z-index: 2;
    inset: auto 0 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px clamp(16px, 3vw, 30px);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .hero__scroll,
  .hero__proof {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .hero__scroll-ring {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border: 1px solid var(--line-2);
    border-radius: 50%;
    font-size: 11px;
  }
  .hero__proof-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
  }

  @media (max-width: 720px) {
    .hero__band {
      font-size: 10px;
      letter-spacing: 0.06em;
    }
    .hero__proof {
      display: none;
    }
  }
</style>

<script>
  import '../scripts/hero.ts';
  import '../scripts/reveal.ts';
</script>
