---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ProofBento from '../components/ProofBento.astro';
import Privacy from '../components/Privacy.astro';
import VenueModes from '../components/VenueModes.astro';
import Open from '../components/Open.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Build from '../components/Build.astro';
import FinalCta from '../components/FinalCta.astro';
import Horizon from '../components/Horizon.astro';
import { REPO, SPEC } from '../site.ts';

// Hero proof panel: the same pair quoted across four venues. OneSwap is the
// highest quote, so it is the winner / best route. The tick swing (+-0.03) keeps
// OneSwap highest by construction, so the demo stays consistent.
const quotes = [
  { venue: 'Cantex', price: '124.72', win: false },
  { venue: 'OneSwap', price: '125.04', win: true },
  { venue: 'HydraX', price: '124.55', win: false },
  { venue: 'Temple', price: '124.81', win: false },
];
---

<Base>
  <main id="main">
    <!-- ===== HERO stage: the inset card expands to full-bleed on scroll ===== -->
    <div class="stage" data-stage>
      <div class="stage__viewport">
        <div class="stage__card">
          <Nav />

          <section class="hero" aria-labelledby="hero-title">
            <Eyebrow
              class="an d1"
              text="Open best-execution layer for Canton"
            />

            <h1 class="hero__headline" id="hero-title">
              <span class="hero__l1 an d2">Best execution,</span>
              <span class="hero__l2 an d3">native to Canton.</span>
            </h1>

            <p class="hero__sub an d4">
              The open, neutral layer that routes every trade across Canton's
              liquidity for the best price, then settles it in one atomic,
              private transaction.
            </p>

            <div class="hero__cta an d5">
              <Button
                variant="primary"
                href={SPEC}
                target="_blank"
                rel="noopener noreferrer"
              >
                Read the spec
                <svg
                  class="ext-arrow"
                  width="13"
                  height="13"
                  viewBox="0 0 13 13"
                  aria-hidden="true"
                >
                  <path
                    d="M3 10 L10 3 M4.6 3 H10 V8.4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </Button>
              <Button
                variant="ghost"
                href={REPO}
                target="_blank"
                rel="noopener noreferrer">View on GitHub</Button
              >
            </div>

            <aside class="proof an d6" aria-label="Best route, illustrative">
              <div class="proof__head">
                <span class="proof__venue">OneSwap</span>
                <span class="proof__pill mono">Best route</span>
              </div>
              <div class="proof__hr"></div>
              <div class="proof__quotes" aria-hidden="true">
                {
                  quotes.map((q) => (
                    <div class:list={['proof__q', q.win && 'is-win']}>
                      <div class="proof__qn">{q.venue}</div>
                      <div class="proof__qp mono" data-base={q.price}>
                        {q.price}
                      </div>
                    </div>
                  ))
                }
              </div>
              <div class="proof__hr"></div>
              <div class="proof__row">
                <span class="proof__k mono">Receive</span>
                <span class="proof__v mono">39,940 USDCx</span>
              </div>
              <div class="proof__row">
                <span class="proof__k mono">Edge vs next</span>
                <span class="proof__v proof__v--em mono">+47.8 bps</span>
              </div>
            </aside>
          </section>
        </div>
      </div>
    </div>

    <!-- ===== Reveal: the full-bleed card flows into this section ===== -->
    <section class="reveal" aria-label="How it works">
      <Eyebrow text="How it works" />
      <div class="reveal__steps">
        <article class="reveal__step">
          <div class="reveal__t">Quotes</div>
          <p class="reveal__d">
            RFQ across every Canton venue, normalized into one comparable quote.
          </p>
        </article>
        <article class="reveal__step">
          <div class="reveal__t">Route</div>
          <p class="reveal__d">
            Depth-aware optimal split for the best execution price.
          </p>
        </article>
        <article class="reveal__step">
          <div class="reveal__t">Atomic settle</div>
          <p class="reveal__d">
            All legs co-execute in one all-or-nothing, per-leg private Daml
            transaction.
          </p>
        </article>
      </div>
    </section>

    <!-- Existing sections (unchanged; deeper reconciliation out of scope) -->
    <Problem />
    <Horizon />
    <HowItWorks />
    <Horizon />
    <ProofBento />
    <Horizon />
    <Privacy />
    <Horizon />
    <VenueModes />
    <Horizon />
    <Open />
    <Horizon />
    <Ecosystem />
    <Horizon />
    <Build />
    <Horizon />
    <FinalCta />
  </main>

  <Footer />
</Base>

<style>
  /* ===== Stage + sticky viewport + expanding card ===== */
  .stage {
    position: relative;
    height: 200vh;
  }
  .stage__viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    display: flex;
    padding: var(--hero-pad, 22px);
  }
  .stage__card {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--hero-rad, 28px);
    background: linear-gradient(180deg, var(--bg-1), var(--bg-0));
    box-shadow: var(--card-inset), var(--card-shadow);
    will-change: border-radius;
  }
  /* One ambient only: a soft ember glow near top-center + a faint white sheen.
     Both decorative, never lowering headline/subhead contrast (they sit below). */
  .stage__card::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      600px 500px at 50% 7%,
      rgba(255, 106, 61, 0.14),
      rgba(255, 106, 61, 0.04) 48%,
      transparent 72%
    );
  }
  .stage__card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      500px 340px at 50% 3%,
      rgba(255, 255, 255, 0.05),
      transparent 70%
    );
  }

  /* The Nav rides inside the card (expands with it), so neutralize its sticky. */
  .stage__card :global(.nav) {
    position: relative;
    top: auto;
    z-index: 2;
  }

  /* ===== Hero spine: fits one viewport, vertically centered ===== */
  .hero {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(8px, 2vh, 24px) var(--gutter);
  }
  .hero__headline {
    margin-top: clamp(12px, 2.2vh, 26px);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, min(7vw, 9.2vh), 5.25rem);
    line-height: 1;
    letter-spacing: -0.025em;
    max-width: 15ch;
  }
  .hero__l1 {
    display: block;
    color: var(--ink);
  }
  .hero__l2 {
    display: block;
    color: var(--ink-display-2);
  }
  .hero__sub {
    margin-top: clamp(12px, 2vh, 24px);
    font-family: var(--font-ui);
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 680px;
  }
  .hero__cta {
    margin-top: clamp(16px, 2.6vh, 32px);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  /* Size the shared Button to the hero spec (50px / radius 25 / 16px) in place. */
  .hero__cta :global(.btn) {
    height: 50px;
    padding: 0 26px;
    font-size: 16px;
    border-radius: 25px;
  }
  .ext-arrow {
    display: block;
  }

  /* ===== Proof panel ===== */
  .proof {
    margin-top: clamp(18px, 3vh, 38px);
    width: 100%;
    max-width: 600px;
    text-align: left;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 20px 24px;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
  }
  .proof__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .proof__venue {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 17px;
    color: var(--ink);
  }
  .proof__pill {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ember-tx);
    border: 1px solid rgba(255, 106, 61, 0.4);
    border-radius: 7px;
    padding: 5px 10px;
  }
  .proof__hr {
    height: 1px;
    background: var(--line);
    margin: 14px 0;
  }
  .proof__quotes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }
  .proof__q {
    padding-left: 11px;
    border-left: 2px solid transparent;
  }
  .proof__qn {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-2);
  }
  .proof__qp {
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 3px;
    font-variant-numeric: tabular-nums;
  }
  .proof__q.is-win {
    border-left-color: var(--ember);
  }
  .proof__q.is-win .proof__qn,
  .proof__q.is-win .proof__qp {
    color: var(--ember-tx);
  }
  .proof__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .proof__row + .proof__row {
    margin-top: 9px;
  }
  .proof__k {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .proof__v {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .proof__v--em {
    color: var(--ember-tx);
  }

  /* ===== Reveal section (revealed as the card grows full-bleed) ===== */
  .reveal {
    position: relative;
    background: var(--bg-0);
    padding: clamp(80px, 14vh, 150px) var(--gutter);
    text-align: center;
  }
  .reveal :global(.eyebrow) {
    justify-content: center;
  }
  .reveal__steps {
    margin: 34px auto 0;
    max-width: 760px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .reveal__step {
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 22px 20px;
    text-align: left;
    background: rgba(241, 239, 234, 0.015);
  }
  .reveal__t {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 16px;
    color: var(--ink);
  }
  .reveal__d {
    margin-top: 6px;
    font-family: var(--font-ui);
    font-weight: 400;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--ink-3);
  }

  /* ===== Motion (all gated by prefers-reduced-motion) ===== */
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes hero-pill-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(255, 106, 61, 0);
    }
    50% {
      box-shadow: 0 0 0 4px rgba(255, 106, 61, 0.1);
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    .an {
      opacity: 0;
      animation: hero-rise 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }
    .d1 {
      animation-delay: 0.05s;
    }
    .d2 {
      animation-delay: 0.12s;
    }
    .d3 {
      animation-delay: 0.19s;
    }
    .d4 {
      animation-delay: 0.28s;
    }
    .d5 {
      animation-delay: 0.37s;
    }
    .d6 {
      animation-delay: 0.46s;
    }
    .proof__pill {
      animation: hero-pill-pulse 3.6s ease-in-out 1.2s infinite;
    }
  }

  /* Reduced motion: no expansion, no pinned empty scroll, final inset state. */
  @media (prefers-reduced-motion: reduce) {
    .stage {
      height: auto;
    }
    .stage__viewport {
      position: relative;
      height: auto;
      min-height: 100dvh;
      padding: 22px;
    }
  }

  /* ===== Responsive ===== */
  @media (max-width: 560px) {
    .proof {
      max-width: 100%;
    }
    .proof__quotes {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px 0;
    }
    .reveal__steps {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Scroll-expand: map scroll progress across the pinned stage to the card's
  // padding (22 -> 0) and corner radius (28 -> 0), finishing at 72% of the
  // range. rAF + passive listener; no layout thrash beyond the card box. The
  // quote strip ticks by tiny amounts (decorative, aria-hidden). Both are
  // skipped entirely under prefers-reduced-motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const stage = document.querySelector<HTMLElement>('[data-stage]');

  if (stage && !reduce) {
    const PAD = 22;
    const RAD = 28;
    const EXP = 0.72;
    let ticking = false;

    const update = (): void => {
      ticking = false;
      const top = stage.getBoundingClientRect().top;
      const total = stage.offsetHeight - window.innerHeight;
      const p = total > 0 ? Math.min(Math.max(-top, 0), total) / total : 0;
      const e = Math.min(p / EXP, 1);
      stage.style.setProperty('--hero-pad', (PAD * (1 - e)).toFixed(2) + 'px');
      stage.style.setProperty('--hero-rad', (RAD * (1 - e)).toFixed(2) + 'px');
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
    window.addEventListener('resize', update);
    update();

    const cells = Array.from(
      document.querySelectorAll<HTMLElement>('.proof__qp'),
    );
    window.setInterval(() => {
      for (const el of cells) {
        const base = parseFloat(el.getAttribute('data-base') || '0');
        el.textContent = (base + (Math.random() - 0.5) * 0.06).toFixed(2);
      }
    }, 2600);
  }
</script>

<script>
  import '../scripts/orbital.ts';
  import '../scripts/proof.ts';
  import '../scripts/reveal.ts';
</script>
