---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import HeroProof from '../components/HeroProof.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ProofBento from '../components/ProofBento.astro';
import Privacy from '../components/Privacy.astro';
import VenueModes from '../components/VenueModes.astro';
import Open from '../components/Open.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Build from '../components/Build.astro';
import FinalCta from '../components/FinalCta.astro';
import Horizon from '../components/Horizon.astro';
import { REPO, SPEC } from '../site.ts';
---

<Base>
  <Nav />

  <main id="main">
    <!-- ===================== HERO - one centered editorial spine, one contained proof ===================== -->
    <section class="hero" data-hero aria-labelledby="hero-title">
      <div class="container">
        <div class="hero__panel">
          <div class="hero__ambient" aria-hidden="true"></div>

          <div class="hero__spine">
            <Eyebrow text="Open best-execution layer for Canton" data-anim />

            <h1 class="hero__headline" id="hero-title" data-anim>
              <span class="hero__line">Best execution,</span>
              <span class="hero__line hero__line--2">native to Canton.</span>
            </h1>

            <p class="hero__sub" data-anim>
              The open, neutral layer that routes every trade across Canton's
              liquidity for the best price, then settles in one atomic, private
              transaction.
            </p>

            <div class="hero__cta" data-anim>
              <Button
                variant="primary"
                href={SPEC}
                target="_blank"
                rel="noopener noreferrer">Read the spec ↗</Button
              >
              <Button
                variant="ghost"
                href={REPO}
                target="_blank"
                rel="noopener noreferrer">View on GitHub</Button
              >
            </div>

            <HeroProof class="hero__proof" data-anim />
          </div>
        </div>
      </div>
    </section>

    <!-- §2 - The problem -->
    <Problem />

    <Horizon />
    <!-- §3 - How it works (the router orbital) -->
    <HowItWorks />

    <Horizon />
    <!-- §4 - Proof / Insights bento -->
    <ProofBento />

    <Horizon />
    <!-- §5 - Per-leg privacy -->
    <Privacy />

    <Horizon />
    <!-- §6 - How venues plug in (settlement modes) -->
    <VenueModes />

    <Horizon />
    <!-- §7 - Open by design -->
    <Open />

    <Horizon />
    <!-- §8 - For the ecosystem -->
    <Ecosystem />

    <Horizon />
    <!-- Build - real @synfin SDK example -->
    <Build />

    <Horizon />
    <!-- Final CTA strip (above the footer) -->
    <FinalCta />
  </main>

  <Footer />
</Base>

<style>
  .hero {
    padding-top: 8px;
    padding-bottom: var(--section-y);
  }

  .hero__panel {
    position: relative;
    overflow: hidden;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--panel-radius);
    box-shadow: var(--card-inset), var(--card-shadow);
    padding: clamp(64px, 9vw, 132px) var(--gutter);
    display: flex;
    justify-content: center;
  }

  /* One subtle ambient treatment: a soft cool highlight at top-center over a
     fainter ember wash, fading into the canvas. No arcs, nothing crosses type. */
  .hero__ambient {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
        56% 40% at 50% -8%,
        rgba(241, 239, 234, 0.09),
        transparent 60%
      ),
      radial-gradient(38% 32% at 50% -2%, var(--ember-glow), transparent 66%);
  }

  .hero__spine {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 26px;
  }

  .hero__headline {
    display: flex;
    flex-direction: column;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(3rem, 6.5vw, 6rem);
    line-height: 1;
    letter-spacing: -0.025em;
  }
  .hero__line {
    white-space: nowrap;
  }
  /* Line 2: a deliberate display grey, distinct from the lighter subhead grey. */
  .hero__line--2 {
    color: var(--ink-display-muted);
  }

  .hero__sub {
    max-width: 640px;
    font-family: var(--font-ui);
    font-weight: 400;
    font-size: clamp(1.0625rem, 1.4vw, 1.25rem);
    line-height: 1.5;
    color: var(--ink-2);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    margin-top: 4px;
  }
  /* Size the shared Button up for the hero without touching the component. */
  .hero__cta :global(.btn) {
    padding: 15px 26px;
    font-size: 15px;
  }

  /* The proof is clearly separated and subordinate, well below the CTAs. */
  .hero__proof {
    margin-top: clamp(56px, 7vw, 88px);
  }

  @media (max-width: 560px) {
    .hero__line {
      white-space: normal;
    }
  }

  /* Entrance: pure-CSS staggered fade-up under the existing .is-animatable
     guard. With reduced motion the class is never added (Base.astro), so the
     final state renders immediately. */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  :global(html.is-animatable) .hero :global([data-anim]) {
    animation: heroFadeUp 0.55s var(--e-out) both;
  }
  :global(html.is-animatable) .hero__headline {
    animation-delay: 0.07s;
  }
  :global(html.is-animatable) .hero__sub {
    animation-delay: 0.14s;
  }
  :global(html.is-animatable) .hero__cta {
    animation-delay: 0.21s;
  }
  :global(html.is-animatable) .hero__proof {
    animation-delay: 0.28s;
  }
</style>

<script>
  import '../scripts/orbital.ts';
  import '../scripts/proof.ts';
  import '../scripts/reveal.ts';
</script>
