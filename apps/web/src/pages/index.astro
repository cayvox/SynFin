---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import RouterCard from '../components/RouterCard.astro';
import LedgerTicker from '../components/LedgerTicker.astro';
import { REPO, SPEC } from '../site.ts';

const proof = [
  'Open · Apache-2.0',
  'Built on CIP-0056 & 0112',
  '10/10 on-ledger tests',
];
const aggregating = [
  'CantonSwap',
  'OneSwap',
  'CompassSwap',
  'Cantex',
  'RFQ desks',
];
---

<Base>
  <Nav />

  <main id="main">
    <!-- ===================== HERO (CONTENT.md §1) ===================== -->
    <section class="hero" data-hero>
      <div class="container hero__grid">
        <div class="hero__copy">
          <Eyebrow text="Open best-execution layer · Canton" data-anim />

          <h1 class="hero__headline" data-anim>
            Best execution, <em>native</em> to Canton.
          </h1>

          <p class="hero__sub" data-anim>
            Synfin gathers quotes across Canton's venues, routes to the best
            price, and settles the split in one atomic transaction, with proven
            per-leg privacy. The open, neutral aggregation layer for Canton —
            built on the token standard, not a venue.
          </p>

          <div class="hero__cta" data-anim>
            <Button
              variant="primary"
              href={SPEC}
              target="_blank"
              rel="noopener noreferrer">Read the specification</Button
            >
            <Button
              variant="secondary"
              href={REPO}
              target="_blank"
              rel="noopener noreferrer">View on GitHub</Button
            >
          </div>

          <ul class="hero__proof mono" data-anim>
            {proof.map((p) => <li class="hero__proof-item">{p}</li>)}
          </ul>
        </div>

        <div class="hero__card" data-anim>
          <RouterCard />
        </div>
      </div>

      <div class="container hero__agg" data-anim>
        <span class="hero__agg-label">Aggregating across</span>
        <ul class="hero__agg-list">
          {aggregating.map((v) => <li class="hero__agg-item">{v}</li>)}
        </ul>
      </div>
    </section>

    {/* TODO(Phase 2 — CONTENT.md): 02 The problem (#problem) */}
    {/* TODO(Phase 2 — CONTENT.md): 03 How it works (#how-it-works) */}
    {/* TODO(Phase 2 — CONTENT.md): 04 The proof (#proof) */}
    {/* TODO(Phase 2 — CONTENT.md): 05 Per-leg privacy (#privacy) */}
    {/* TODO(Phase 2 — CONTENT.md): 06 How venues plug in (#architecture) */}
    {/* TODO(Phase 2 — CONTENT.md): 07 Open by design (#open) */}
    {/* TODO(Phase 2 — CONTENT.md): 08 For the ecosystem (#ecosystem) */}
    {
      /* TODO(Phase 3 — DESIGN.md §7): paper grain + guilloché watermark + engraved dividers */
    }
  </main>

  <LedgerTicker />
  <Footer />
</Base>

<style>
  .hero {
    padding-top: var(--s-11);
    padding-bottom: var(--s-9);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: var(--s-10);
  }

  .hero__headline {
    margin-top: var(--s-5);
    font-size: var(--t-hero);
    line-height: 0.98;
    letter-spacing: -0.012em;
    max-width: 13ch;
  }
  .hero__headline em {
    font-style: italic;
    font-weight: 400;
  }

  .hero__sub {
    margin-top: var(--s-5);
    max-width: 46ch;
    font-size: var(--t-5);
    line-height: 1.5;
    color: var(--ink-2);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3);
    margin-top: var(--s-7);
  }

  .hero__proof {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2) var(--s-5);
    margin-top: var(--s-7);
    padding: 0;
    list-style: none;
  }
  .hero__proof-item {
    position: relative;
    font-size: var(--t-1);
    letter-spacing: 0.02em;
    color: var(--ink-3);
  }
  .hero__proof-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(-1 * var(--s-3));
    top: 50%;
    width: 1px;
    height: 11px;
    transform: translateY(-50%);
    background: var(--line-2);
  }

  .hero__card {
    display: flex;
    justify-content: flex-end;
  }

  .hero__agg {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-3) var(--s-5);
    margin-top: var(--s-11);
    padding-top: var(--s-6);
    border-top: var(--hairline) solid var(--line);
  }
  .hero__agg-label {
    font-family: var(--font-ui);
    font-size: var(--t-2);
    color: var(--ink-3);
  }
  .hero__agg-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-3) var(--s-5);
    list-style: none;
    padding: 0;
  }
  .hero__agg-item {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--t-3);
    color: var(--ink-2);
  }

  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--s-9);
    }
    .hero__card {
      justify-content: flex-start;
    }
  }
  @media (max-width: 640px) {
    .hero {
      padding-top: var(--s-9);
    }
    .hero__card .rc {
      max-width: 100%;
    }
  }
</style>

<script>
  import '../scripts/hero.ts';
  import '../scripts/reveal.ts';
</script>
