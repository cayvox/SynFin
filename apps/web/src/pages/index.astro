---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Constellation from '../components/Constellation.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ProofBento from '../components/ProofBento.astro';
import Privacy from '../components/Privacy.astro';
import VenueModes from '../components/VenueModes.astro';
import Open from '../components/Open.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Build from '../components/Build.astro';
import FinalCta from '../components/FinalCta.astro';
import Horizon from '../components/Horizon.astro';
import { REPO, SPEC } from '../site.ts';
---

<Base>
  <Nav />

  <main id="main">
    <!-- ===================== HERO — routing constellation (DESIGN.md §6/§8) ===================== -->
    <section class="hero" data-hero aria-labelledby="hero-title">
      <div class="container">
        <div class="hero__panel">
          <Constellation />

          <div class="hero__content">
            <Eyebrow text="Open best-execution layer · Canton" data-anim />

            <h1 class="hero__headline" id="hero-title" data-anim>
              <span class="hero__line">Best execution,</span>
              <span class="hero__line hero__line--muted">native to Canton.</span
              >
            </h1>

            <p class="hero__sub" data-anim>
              Synfin aggregates quotes across every Canton venue, routes to the
              best price, and settles the split in one atomic transaction — with
              per-leg privacy.
            </p>

            <div class="hero__cta" data-anim>
              <Button
                variant="primary"
                href={SPEC}
                target="_blank"
                rel="noopener noreferrer">Read the spec ↗</Button
              >
              <Button
                variant="ghost"
                href={REPO}
                target="_blank"
                rel="noopener noreferrer">View on GitHub</Button
              >
            </div>

            <!-- Static best-route chip — shown only below 1024px, where the
                 full constellation is hidden (Fix 5). Sits clearly below the
                 CTAs; never overlaps them. -->
            <p class="hero__chip mono" data-anim>
              <span class="hero__chip-dot" aria-hidden="true"></span>
              best route · +47.8 bps
            </p>
          </div>

          <div class="hero__band">
            <span class="hero__scroll mono">
              <span class="hero__scroll-ring" aria-hidden="true">↓</span>
              01 / 03 · SCROLL
            </span>
            <span class="hero__proof mono">
              <span class="hero__proof-dot" aria-hidden="true"></span>
              built on CIP-0056 / 0112 · 10/10 on-ledger tests
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- §2 — The problem -->
    <Problem />

    <Horizon />
    <!-- §3 — How it works (the router orbital) -->
    <HowItWorks />

    <Horizon />
    <!-- §4 — Proof / Insights bento -->
    <ProofBento />

    <Horizon />
    <!-- §5 — Per-leg privacy -->
    <Privacy />

    <Horizon />
    <!-- §6 — How venues plug in (settlement modes) -->
    <VenueModes />

    <Horizon />
    <!-- §7 — Open by design -->
    <Open />

    <Horizon />
    <!-- §8 — For the ecosystem -->
    <Ecosystem />

    <Horizon />
    <!-- Build — real @synfin SDK example -->
    <Build />

    <Horizon />
    <!-- Final CTA strip (above the footer) -->
    <FinalCta />
  </main>

  <Footer />
</Base>

<style>
  .hero {
    padding-top: 8px;
    padding-bottom: var(--section-y);
  }

  .hero__panel {
    position: relative;
    overflow: hidden;
    min-height: clamp(520px, 92vw, 640px);
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: var(--panel-radius);
    box-shadow: var(--card-inset), var(--card-shadow);
    display: grid;
    place-items: center;
  }
  /* Desktop: lock the panel to the constellation viewBox aspect (1440:856) so
     the fixed-viewBox SVG maps 1:1 — no non-uniform stretch, line ends meet node
     centres (Fix 6). */
  @media (min-width: 1024px) {
    .hero__panel {
      min-height: 0;
      aspect-ratio: 1440 / 856;
    }
  }

  .hero__content {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 22px;
    max-width: 660px;
    padding: 40px var(--gutter);
  }

  .hero__headline {
    display: flex;
    flex-direction: column;
    font-size: clamp(34px, 6.2vw, 80px);
    line-height: 0.97;
    letter-spacing: -0.035em;
  }
  .hero__line {
    white-space: nowrap;
  }
  .hero__line--muted {
    color: var(--ink-display-muted);
  }
  @media (max-width: 460px) {
    .hero__line {
      white-space: normal;
    }
  }

  .hero__sub {
    max-width: 560px;
    font-size: clamp(16px, 2.2vw, 19px);
    line-height: 1.5;
    color: var(--ink-2);
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-top: 6px;
  }

  /* Static chip (mobile/tablet only) */
  .hero__chip {
    display: none;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding: 6px 13px;
    font-size: 12.5px;
    letter-spacing: 0.02em;
    color: var(--ember-hi);
    background: color-mix(in srgb, var(--bg) 86%, var(--ember) 14%);
    border: 1px solid var(--ember-soft);
    border-radius: var(--r-pill);
  }
  .hero__chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
  }
  @media (max-width: 1023px) {
    .hero__chip {
      display: inline-flex;
    }
  }

  /* Bottom band */
  .hero__band {
    position: absolute;
    z-index: 3;
    inset: auto 0 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px clamp(16px, 3vw, 30px);
    font-size: 11.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .hero__scroll,
  .hero__proof {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .hero__scroll-ring {
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border: 1px solid var(--line-2);
    border-radius: 50%;
    font-size: 11px;
  }
  .hero__proof-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
  }

  @media (max-width: 720px) {
    .hero__band {
      font-size: 10px;
      letter-spacing: 0.06em;
    }
    .hero__proof {
      display: none;
    }
  }
</style>

<script>
  import '../scripts/hero.ts';
  import '../scripts/orbital.ts';
  import '../scripts/proof.ts';
  import '../scripts/reveal.ts';
</script>
