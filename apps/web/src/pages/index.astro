---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Problem from '../components/Problem.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ProofBento from '../components/ProofBento.astro';
import Privacy from '../components/Privacy.astro';
import VenueModes from '../components/VenueModes.astro';
import Open from '../components/Open.astro';
import Ecosystem from '../components/Ecosystem.astro';
import Build from '../components/Build.astro';
import FinalCta from '../components/FinalCta.astro';
import Horizon from '../components/Horizon.astro';
import { REPO, SPEC } from '../site.ts';
import {
  SELL_CC,
  BASE,
  QUOTE,
  ranked,
  best,
  receiveUSDCx,
  edgeVsNextBps,
  fmtPrice,
  fmtBps,
  fmtAmount,
} from '../data/market.ts';

// Hero proof panel: reads the canonical market (src/data/market.ts) so it can
// never disagree with the Problem and How-it-works sections. The strip shows the
// top four venues (winner first); RECEIVE and EDGE are derived, and the live
// tick below recomputes them from drifting quotes. The headline metric is the
// edge over the next best venue.
const PANEL_VENUES = ranked.slice(0, 4);
const metricLabel = 'Edge vs next';
const metricBps = edgeVsNextBps;
---

<Base>
  <Nav />

  <main id="main">
    <!-- ===== HERO stage: the inset card expands to full-bleed on scroll ===== -->
    <div class="stage" data-stage>
      <div class="stage__viewport">
        <div class="stage__card">
          <section class="hero" aria-labelledby="hero-title">
            <Eyebrow
              class="an d1"
              text="Open best-execution layer for Canton"
            />

            <h1 class="hero__headline" id="hero-title">
              <span class="hero__l1 an d2">Best execution,</span>
              <span class="hero__l2 an d3">native to Canton.</span>
            </h1>

            <p class="hero__sub an d4">
              The open, neutral layer that routes every trade across Canton's
              liquidity for the best price, then settles it in one atomic,
              private transaction.
            </p>

            <div class="hero__cta an d5">
              <Button
                variant="primary"
                href={SPEC}
                target="_blank"
                rel="noopener noreferrer"
              >
                Read the spec
                <svg
                  class="ext-arrow"
                  width="13"
                  height="13"
                  viewBox="0 0 13 13"
                  aria-hidden="true"
                >
                  <path
                    d="M3 10 L10 3 M4.6 3 H10 V8.4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </Button>
              <Button
                variant="ghost"
                href={REPO}
                target="_blank"
                rel="noopener noreferrer">View on GitHub</Button
              >
            </div>

            <aside class="proof an d6" aria-label="Best route, illustrative">
              <div class="proof__head">
                <div class="proof__id">
                  <span class="proof__venue">{best.name}</span>
                  <span class="proof__sub mono">{BASE} &#8594; {QUOTE}</span>
                </div>
                <span class="proof__pill mono">Best route</span>
              </div>
              <div class="proof__hr"></div>
              <div class="proof__quotes" aria-hidden="true">
                {
                  PANEL_VENUES.map((v) => (
                    <div
                      class:list={[
                        'proof__q',
                        v.name === best.name && 'is-win',
                      ]}
                    >
                      <div class="proof__qn">{v.name}</div>
                      <div class="proof__qp mono" data-base={fmtPrice(v.price)}>
                        {fmtPrice(v.price)}
                      </div>
                    </div>
                  ))
                }
              </div>
              <div class="proof__hr"></div>
              <div class="proof__row">
                <span class="proof__k mono">Sell</span>
                <span class="proof__v mono">{fmtAmount(SELL_CC)} {BASE}</span>
              </div>
              <div class="proof__row">
                <span class="proof__k mono">Receive</span>
                <span class="proof__v mono" data-receive
                  >{fmtAmount(receiveUSDCx)} {QUOTE}</span
                >
              </div>
              <div class="proof__row">
                <span class="proof__k mono">{metricLabel}</span>
                <span class="proof__v proof__v--em mono" data-edge
                  >+{fmtBps(metricBps)} bps</span
                >
              </div>
            </aside>
          </section>
        </div>
      </div>
    </div>

    <!-- The full-bleed card flows directly into the existing sections. -->
    <Problem />
    <Horizon />
    <HowItWorks />
    <Horizon />
    <ProofBento />
    <Horizon />
    <Privacy />
    <Horizon />
    <VenueModes />
    <Horizon />
    <Open />
    <Horizon />
    <Ecosystem />
    <Horizon />
    <Build />
    <Horizon />
    <FinalCta />
  </main>

  <Footer />
</Base>

<style>
  /* ===== Stage + sticky viewport + expanding card ===== */
  /* The persistent nav is a page-level sticky header. Pull the stage up under it
     by the nav height so the card fills the full viewport and the nav floats
     over it (the card expands under the nav, no seam at the top edge), while the
     nav stays visible across every section below. */
  .stage {
    --nav-h: 70px;
    position: relative;
    height: 200vh;
    margin-top: calc(-1 * var(--nav-h));
  }
  .stage__viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    display: flex;
    padding: var(--hero-pad, 22px);
  }
  .stage__card {
    position: relative;
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--hero-rad, 28px);
    background: linear-gradient(180deg, var(--bg-1), var(--bg-0));
    box-shadow: var(--card-inset), var(--card-shadow);
    will-change: border-radius;
  }
  /* One ambient only: a soft ember glow near top-center + a faint white sheen.
     Both decorative, never lowering headline/subhead contrast (they sit below). */
  .stage__card::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      600px 500px at 50% 7%,
      rgba(255, 106, 61, 0.14),
      rgba(255, 106, 61, 0.04) 48%,
      transparent 72%
    );
  }
  .stage__card::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      500px 340px at 50% 3%,
      rgba(255, 255, 255, 0.05),
      transparent 70%
    );
  }

  /* ===== Hero spine: fits one viewport, vertically centered ===== */
  .hero {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(8px, 2vh, 24px) var(--gutter);
    /* The card fills the viewport behind the floating nav (no top seam); the
       content centers BELOW the nav so it never collides with it. */
    padding-top: calc(var(--nav-h) + clamp(8px, 2vh, 24px));
  }
  .hero__headline {
    margin-top: clamp(12px, 2.2vh, 26px);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, min(7vw, 9.2vh), 5.25rem);
    line-height: 1;
    letter-spacing: -0.025em;
    max-width: 15ch;
  }
  .hero__l1 {
    display: block;
    color: var(--ink);
  }
  .hero__l2 {
    display: block;
    color: var(--ink-display-2);
  }
  .hero__sub {
    margin-top: clamp(12px, 2vh, 24px);
    font-family: var(--font-ui);
    font-weight: 400;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 680px;
  }
  .hero__cta {
    margin-top: clamp(16px, 2.6vh, 32px);
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  /* Size the shared Button to the hero spec (50px / radius 25 / 16px) in place. */
  .hero__cta :global(.btn) {
    height: 50px;
    padding: 0 26px;
    font-size: 16px;
    border-radius: 25px;
  }
  .ext-arrow {
    display: block;
  }

  /* ===== Proof panel ===== */
  .proof {
    margin-top: clamp(18px, 3vh, 38px);
    width: 100%;
    max-width: 600px;
    text-align: left;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: clamp(16px, 2.4vh, 20px) 24px;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.5);
  }
  .proof__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .proof__id {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .proof__venue {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 17px;
    color: var(--ink);
  }
  .proof__sub {
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--ink-3);
  }
  .proof__pill {
    flex: none;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ember-tx);
    border: 1px solid rgba(255, 106, 61, 0.4);
    border-radius: 7px;
    padding: 5px 10px;
  }
  .proof__hr {
    height: 1px;
    background: var(--line);
    margin: clamp(11px, 1.6vh, 14px) 0;
  }
  .proof__quotes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0 6px;
  }
  .proof__q {
    padding: 6px 8px 6px 11px;
    border-left: 3px solid transparent;
    border-radius: 0 6px 6px 0;
  }
  .proof__qn {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-2);
  }
  .proof__qp {
    font-weight: 500;
    font-size: 12px;
    color: var(--ink-3);
    margin-top: 3px;
    font-variant-numeric: tabular-nums;
  }
  /* Winner cell: faint ember-tint background + 3px ember left border + ember text. */
  .proof__q.is-win {
    background: rgba(255, 106, 61, 0.06);
    border-left-color: var(--ember);
  }
  .proof__q.is-win .proof__qn,
  .proof__q.is-win .proof__qp {
    color: var(--ember-tx);
  }
  .proof__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .proof__row + .proof__row {
    margin-top: clamp(7px, 1vh, 9px);
  }
  .proof__k {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .proof__v {
    font-size: 14.5px;
    font-weight: 500;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .proof__v--em {
    color: var(--ember-tx);
  }

  /* ===== Motion (all gated by prefers-reduced-motion) ===== */
  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @keyframes hero-pill-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(255, 106, 61, 0);
    }
    50% {
      box-shadow: 0 0 0 4px rgba(255, 106, 61, 0.1);
    }
  }
  @media (prefers-reduced-motion: no-preference) {
    .an {
      opacity: 0;
      animation: hero-rise 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
    }
    .d1 {
      animation-delay: 0.05s;
    }
    .d2 {
      animation-delay: 0.12s;
    }
    .d3 {
      animation-delay: 0.19s;
    }
    .d4 {
      animation-delay: 0.28s;
    }
    .d5 {
      animation-delay: 0.37s;
    }
    .d6 {
      animation-delay: 0.46s;
    }
    .proof__pill {
      animation: hero-pill-pulse 3.6s ease-in-out 1.2s infinite;
    }
  }

  /* Reduced motion: no expansion, no pinned empty scroll, final inset state. */
  @media (prefers-reduced-motion: reduce) {
    .stage {
      height: auto;
    }
    .stage__viewport {
      position: relative;
      height: auto;
      min-height: 100dvh;
      padding: 22px;
    }
  }

  /* ===== Responsive ===== */
  @media (max-width: 560px) {
    /* On phones the content is taller than one viewport and the inset-to-bleed
       expand is barely perceptible, so render the hero static (like the
       reduced-motion path): the card grows with its content and nothing clips.
       The expand rAF is gated to wider screens in the script. */
    .stage {
      height: auto;
    }
    .stage__viewport {
      position: relative;
      height: auto;
      min-height: 100dvh;
      padding: 22px;
    }
    /* Top-align below the nav (centering would push the eyebrow under it). */
    .hero {
      justify-content: flex-start;
      padding-top: calc(var(--nav-h) + 12px);
    }
    .hero__headline {
      margin-top: 14px;
    }
    .hero__sub {
      margin-top: 12px;
    }
    .hero__cta {
      margin-top: 18px;
    }
    .proof {
      max-width: 100%;
      margin-top: 20px;
      padding: 16px 18px;
    }
    .proof__hr {
      margin: 11px 0;
    }
    .proof__quotes {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px 0;
    }
  }
</style>

<script>
  import { SELL_CC, QUOTE, fmtAmount } from '../data/market.ts';
  // Scroll-expand: map scroll progress across the pinned stage to the card's
  // padding (22 -> 0) and corner radius (28 -> 0), finishing at 72% of the
  // range. rAF + passive listener; the only per-frame layout is the card box
  // inside the pinned viewport (content is centered, so it does not reflow).
  // The proof quotes tick by tiny amounts and RECEIVE + EDGE are recomputed from
  // them each tick, so the panel stays internally consistent (the small drift
  // preserves the descending order, so OneSwap stays the winner). Decorative,
  // aria-hidden, and skipped entirely under prefers-reduced-motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  // The expand is a wider-screen flourish; on phones the hero is static (CSS).
  const wide = window.matchMedia('(min-width: 561px)').matches;
  const stage = document.querySelector<HTMLElement>('[data-stage]');

  if (stage && !reduce) {
    if (wide) {
      const PAD = 22;
      const RAD = 28;
      const EXP = 0.72;
      let ticking = false;

      const update = (): void => {
        ticking = false;
        const top = stage.getBoundingClientRect().top;
        const total = stage.offsetHeight - window.innerHeight;
        const p = total > 0 ? Math.min(Math.max(-top, 0), total) / total : 0;
        const e = Math.min(p / EXP, 1);
        stage.style.setProperty(
          '--hero-pad',
          (PAD * (1 - e)).toFixed(2) + 'px',
        );
        stage.style.setProperty(
          '--hero-rad',
          (RAD * (1 - e)).toFixed(2) + 'px',
        );
      };

      window.addEventListener(
        'scroll',
        () => {
          if (!ticking) {
            window.requestAnimationFrame(update);
            ticking = true;
          }
        },
        { passive: true },
      );
      window.addEventListener('resize', update);
      update();
    }

    // Live tick: drift quotes by a tiny amount that preserves their descending
    // order (so OneSwap stays highest), then recompute RECEIVE and EDGE from the
    // live values. Quotes never drift while the results stay static.
    const cells = Array.from(
      document.querySelectorAll<HTMLElement>('.proof__qp'),
    );
    const bases = cells.map((el) => parseFloat(el.dataset.base || '0'));
    const receiveEl = document.querySelector<HTMLElement>('[data-receive]');
    const edgeEl = document.querySelector<HTMLElement>('[data-edge]');

    window.setInterval(() => {
      const vals = bases.map((b) => b + (Math.random() - 0.5) * 0.04);
      vals.forEach((v, i) => {
        const el = cells[i];
        if (el) el.textContent = v.toFixed(2);
      });
      const top = vals[0];
      const next = vals[1];
      if (top === undefined || next === undefined) return;
      if (receiveEl)
        receiveEl.textContent = fmtAmount(SELL_CC * top) + ' ' + QUOTE;
      if (edgeEl) {
        const edge = ((top - next) / next) * 1e4;
        edgeEl.textContent = '+' + edge.toFixed(1) + ' bps';
      }
    }, 2600);
  }
</script>

<script>
  import '../scripts/orbital.ts';
  import '../scripts/proof.ts';
  import '../scripts/reveal.ts';
</script>
