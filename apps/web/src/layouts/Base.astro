---
/**
 * Base layout — document head (CONTENT.md meta), self-hosted font preloads
 * (STACK.md), global styles, a visible skip-link, and semantic landmarks.
 */
import '../styles/tokens.css';
import '../styles/fonts.css';
import '../styles/base.css';
import { CANONICAL } from '../site.ts';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}
const {
  title = 'Synfin — Best execution for Canton',
  description = "The open, neutral best-execution aggregation layer for the Canton Network: aggregate quotes across venues, route to the best price, and settle atomically with per-leg privacy — built on Canton's token standard (CIP-0056/0112).",
  canonical = CANONICAL,
} = Astro.props;

// Absolute URL for the social card (OG/Twitter require absolute image URLs).
const ogImage = new URL('/og.png', canonical).href;

// Hero faces to preload (STACK.md / FONTS): Mona Sans 600 + Geist 400/500 +
// Geist Mono 400/500.
const preloadFonts = [
  'MonaSans-600.woff2',
  'Geist-Regular.woff2',
  'Geist-Medium.woff2',
  'GeistMono-Regular.woff2',
  'GeistMono-Medium.woff2',
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Progressive enhancement (DESIGN.md §9): set the hidden pre-animation
         state BEFORE first paint, but ONLY when JS is on AND motion is allowed —
         so there is no visible→hide flash, and no-JS / reduced-motion render the
         final state. A failsafe reveals the content even if the animation module
         never loads (never hide content behind JS that may not run). -->
    <script is:inline>
      (function () {
        try {
          if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
          var d = document.documentElement;
          d.classList.add('is-animatable');
          setTimeout(function () {
            d.classList.remove('is-animatable');
          }, 2600);
        } catch (e) {
          /* render final state */
        }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#070708" />
    <meta name="color-scheme" content="dark" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Synfin" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Synfin — best execution, native to Canton."
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {
      preloadFonts.map((f) => (
        <link
          rel="preload"
          href={`/fonts/${f}`}
          as="font"
          type="font/woff2"
          crossorigin="anonymous"
        />
      ))
    }
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <!-- §7b — the whole body reads as one lit space: a single page-level light
         field behind all content, plus one unified grain over the page. Both are
         decorative (aria-hidden, pointer-events:none) and degrade under
         forced-colors / reduced-transparency (base.css). -->
    <div class="page">
      <div class="page__field" aria-hidden="true"></div>
      <div class="page__content">
        <slot />
      </div>
    </div>
    <div class="page__grain" aria-hidden="true"></div>
  </body>
</html>
