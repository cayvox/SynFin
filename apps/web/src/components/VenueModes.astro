---
/**
 * §5 "How venues plug in" (CONTENT.md §6; DESIGN.md §8b.5) — a centered compare
 * of the two settlement modes every venue adapter declares. Mode A
 * (atomic-allocation) is the ember-blessed path: it co-settles via the token
 * standard and is eligible for Synfin's atomic, per-leg-private settlement. Mode
 * B (managed-deposit) is neutral: quote-and-deposit, deferred, non-atomic. One
 * adapter interface, one `settlementMode` field. The honest note states the real
 * status — most accessible venues today are Mode B; the atomic path turns on as
 * venues adopt CIP-0112's V2 batch settlement.
 */
import Eyebrow from './Eyebrow.astro';

const modeA = ['Atomic co-settlement', 'Per-leg privacy', 'All-or-nothing'];
const modeB = [
  { t: 'quote & deposit', icon: 'plus' },
  { t: 'deferred execution', icon: 'clock' },
  { t: 'non-atomic', icon: 'x' },
];
---

<section id="architecture" class="vm" aria-labelledby="architecture-title">
  <div class="container">
    <header class="vm__head" data-reveal>
      <Eyebrow text="05 — Architecture" />
      <h2 class="vm__title" id="architecture-title">
        <span>Two settlement modes.</span>
        <span class="vm__muted">One adapter interface.</span>
      </h2>
    </header>

    <div class="vm__grid">
      <!-- Mode A — atomic-allocation (ember-blessed) -->
      <article class="vm-mode vm-mode--a card" data-reveal>
        <div class="vm-mode__top">
          <span class="vm-mode__label mono">settlementMode</span>
          <span class="vm-badge vm-badge--on mono">atomic</span>
        </div>
        <h3 class="vm-mode__name">Atomic-allocation</h3>
        <p class="vm-mode__sub">
          Co-settles via the token standard’s allocation / batch-settlement flow
          (CIP-0056 / 0112) — eligible for Synfin’s atomic, per-leg-private
          settlement.
        </p>
        <ul class="vm-rows">
          {
            modeA.map((t) => (
              <li class="vm-row vm-row--on">
                <svg
                  class="vm-ic"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M3.5 8.4l3 3 6-6.8"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
        <p class="vm-mode__settles">
          settles via <span class="mono">CIP-0056 / 0112</span>
        </p>
        <p class="vm-chip mono">
          settlementMode: <span class="vm-chip__val vm-chip__val--on"
            >'atomic-allocation'</span
          >
        </p>
      </article>

      <!-- Mode B — managed-deposit (neutral) -->
      <article class="vm-mode vm-mode--b card" data-reveal>
        <div class="vm-mode__top">
          <span class="vm-mode__label mono">settlementMode</span>
          <span class="vm-badge mono">deferred</span>
        </div>
        <h3 class="vm-mode__name">Managed-deposit</h3>
        <p class="vm-mode__sub">
          Quote-and-deposit venues; execution is deferred and non-atomic. They
          quote today and route value, but cannot co-settle in one transaction.
        </p>
        <ul class="vm-rows">
          {
            modeB.map((r) => (
              <li class="vm-row">
                <svg
                  class="vm-ic"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  {r.icon === 'plus' && (
                    <path
                      d="M8 3.6v8.8M3.6 8h8.8"
                      stroke="currentColor"
                      stroke-width="1.3"
                      stroke-linecap="round"
                    />
                  )}
                  {r.icon === 'clock' && (
                    <>
                      <circle
                        cx="8"
                        cy="8"
                        r="5"
                        stroke="currentColor"
                        stroke-width="1.2"
                      />
                      <path
                        d="M8 5.2V8l2 1.4"
                        stroke="currentColor"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </>
                  )}
                  {r.icon === 'x' && (
                    <path
                      d="M5 5l6 6M11 5l-6 6"
                      stroke="currentColor"
                      stroke-width="1.3"
                      stroke-linecap="round"
                    />
                  )}
                </svg>
                <span>{r.t}</span>
              </li>
            ))
          }
        </ul>
        <p class="vm-mode__settles vm-mode__settles--muted">
          quote aggregation today · settlement deferred
        </p>
        <p class="vm-chip mono">
          settlementMode: <span class="vm-chip__val">'managed-deposit'</span>
        </p>
      </article>
    </div>

    <p class="vm__note" data-reveal>
      <span class="vm__note-dot" aria-hidden="true"></span>
      <span>
        Atomic settlement is valid only when <em>every</em> leg is Mode A — the router
        enforces it. Most accessible Canton venues today are managed-deposit, and
        CIP-0112’s native batch settlement is rolling out. Synfin’s quote aggregation
        works against venues now; the atomic path is proven and turns on as venues
        adopt the V2 settlement flow.
      </span>
    </p>
  </div>
</section>

<style>
  .vm {
    position: relative;
    padding-block: var(--section-y);
    overflow: hidden;
  }
  .vm > .container {
    position: relative;
    z-index: 1;
    max-width: 1180px;
  }

  .vm__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    margin-bottom: 40px;
  }
  .vm__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    display: flex;
    flex-direction: column;
  }
  .vm__muted {
    color: var(--ink-display-muted);
  }

  .vm__grid {
    display: grid;
    /* minmax(0, 1fr) so each card can shrink below its content's min-content
       width at narrow widths (a bare 1fr floors at min-content → the card
       overflows its container and the mono chip is clipped). */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .vm-mode {
    min-width: 0;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  /* Mode A — faint ember border + an ember top-glow over the card's lit glass. */
  .vm-mode--a {
    border-color: var(--ember-soft);
  }
  .vm-mode--a::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      120% 60% at 50% 0%,
      var(--ember-glow),
      transparent 58%
    );
  }
  .vm-mode > * {
    position: relative;
    z-index: 1;
  }

  .vm-mode__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .vm-mode__label {
    font-size: 11.5px;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }
  .vm-badge {
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: var(--r-pill);
    color: var(--ink-3);
    border: 1px solid var(--line-2);
  }
  .vm-badge--on {
    color: var(--ember-hi);
    border-color: var(--ember-soft);
    background: color-mix(in srgb, var(--bg-1) 82%, var(--ember) 18%);
  }

  .vm-mode__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(22px, 2.6vw, 28px);
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .vm-mode__sub {
    font-family: var(--font-ui);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin-top: -2px;
  }

  .vm-rows {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vm-row {
    display: flex;
    align-items: center;
    gap: 11px;
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--ink);
  }
  .vm-ic {
    width: 16px;
    height: 16px;
    flex: none;
    color: var(--ink-3);
  }
  .vm-row--on .vm-ic {
    color: var(--ember);
  }

  .vm-mode__settles {
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--ink-2);
  }
  .vm-mode__settles .mono {
    color: var(--ink);
  }
  .vm-mode__settles--muted {
    color: var(--ink-3);
  }

  .vm-chip {
    margin-top: 2px;
    padding: 10px 12px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-size: 12px;
    color: var(--ink-3);
    /* Wrap (never force a min-content width that overflows the card at narrow
       widths); break the long quoted value if it can't fit on one line. */
    white-space: normal;
    overflow-wrap: anywhere;
  }
  .vm-chip__val {
    color: var(--ink-2);
  }
  .vm-chip__val--on {
    color: var(--ember);
  }

  .vm__note {
    display: flex;
    align-items: flex-start;
    gap: 11px;
    max-width: 820px;
    margin: 28px auto 0;
    padding: 16px 18px;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-family: var(--font-ui);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-2);
  }
  .vm__note em {
    font-style: normal;
    color: var(--ink);
  }
  .vm__note-dot {
    margin-top: 6px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
    flex: none;
  }

  /* Mobile: cards stack 1-col (Mode A first, by source order). */
  @media (max-width: 720px) {
    .vm__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  @media (max-width: 460px) {
    .vm-mode {
      padding: 20px;
    }
  }
</style>
