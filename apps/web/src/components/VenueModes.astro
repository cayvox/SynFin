---
/**
 * §5 "How venues plug in" (CONTENT.md §6; DESIGN.md §8b.5) - a centered compare
 * of the two settlement modes every venue adapter declares. Mode A
 * (atomic-allocation) is the ember-blessed path: it co-settles via the token
 * standard and is eligible for Synfin's atomic, per-leg-private settlement. Mode
 * B (managed-deposit) is neutral: quote-and-deposit, deferred, non-atomic. One
 * adapter interface, one `settlementMode` field. The honest note states the real
 * status: atomic settlement is live on Canton today (proven, CIP-0056), but most
 * accessible venues are still managed-deposit, so the atomic path widens as
 * venues adopt the allocation flow; CIP-0112 (Token Standard V2) brings further
 * improvements as it rolls out. A maturation axis shows that trajectory.
 */
import Eyebrow from './Eyebrow.astro';

const modeA = [
  'Atomic co-settlement: all legs in one transaction.',
  'Per-leg privacy: each venue sees only its leg.',
  'All or nothing: settles via CIP-0056 / 0112.',
];
const modeB = [
  { t: 'Quote and deposit: included in routing.', icon: 'plus' },
  { t: 'Deferred execution: not same-transaction.', icon: 'clock' },
  { t: 'Non-atomic: outside the all-or-nothing guarantee.', icon: 'x' },
];
---

<section id="architecture" class="vm" aria-labelledby="architecture-title">
  <div class="container">
    <header class="vm__head" data-reveal>
      <Eyebrow text="Settlement" />
      <h2 class="vm__title" id="architecture-title">
        <span>Two settlement modes.</span>
        <span class="vm__muted">One adapter interface.</span>
      </h2>
    </header>

    <div class="vm__grid">
      <!-- Mode A - atomic-allocation (ember-blessed) -->
      <article class="vm-mode vm-mode--a card" data-reveal>
        <div class="vm-mode__top">
          <span class="vm-mode__label mono">settlementMode</span>
          <span class="vm-badge vm-badge--on mono">atomic</span>
        </div>
        <h3 class="vm-mode__name">Atomic allocation</h3>
        <p class="vm-mode__sub">
          The venue co-settles through the token standard’s allocation flow.
          Eligible for Synfin’s atomic, per-leg-private settlement.
        </p>
        <ul class="vm-rows">
          {
            modeA.map((t) => (
              <li class="vm-row vm-row--on">
                <svg
                  class="vm-ic"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M3.5 8.4l3 3 6-6.8"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
                <span>{t}</span>
              </li>
            ))
          }
        </ul>
        <p class="vm-chip mono">
          settlementMode: <span class="vm-chip__val vm-chip__val--on"
            >'atomic-allocation'</span
          >
        </p>
      </article>

      <!-- Mode B - managed-deposit (neutral) -->
      <article class="vm-mode vm-mode--b card" data-reveal>
        <div class="vm-mode__top">
          <span class="vm-mode__label mono">settlementMode</span>
          <span class="vm-badge mono">deferred</span>
        </div>
        <h3 class="vm-mode__name">Managed deposit</h3>
        <p class="vm-mode__sub">
          Quote-and-deposit venues. Synfin still aggregates their quotes, but
          execution is deferred and settles separately.
        </p>
        <ul class="vm-rows">
          {
            modeB.map((r) => (
              <li class="vm-row">
                <svg
                  class="vm-ic"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  {r.icon === 'plus' && (
                    <path
                      d="M8 3.6v8.8M3.6 8h8.8"
                      stroke="currentColor"
                      stroke-width="1.3"
                      stroke-linecap="round"
                    />
                  )}
                  {r.icon === 'clock' && (
                    <>
                      <circle
                        cx="8"
                        cy="8"
                        r="5"
                        stroke="currentColor"
                        stroke-width="1.2"
                      />
                      <path
                        d="M8 5.2V8l2 1.4"
                        stroke="currentColor"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </>
                  )}
                  {r.icon === 'x' && (
                    <path
                      d="M5 5l6 6M11 5l-6 6"
                      stroke="currentColor"
                      stroke-width="1.3"
                      stroke-linecap="round"
                    />
                  )}
                </svg>
                <span>{r.t}</span>
              </li>
            ))
          }
        </ul>
        <p class="vm-chip mono">
          settlementMode: <span class="vm-chip__val">'managed-deposit'</span>
        </p>
      </article>
    </div>

    <!-- Maturation axis: today's reality on the left, the direction on the right. -->
    <ol
      class="vm-axis"
      data-reveal
      aria-label="Settlement maturation: from managed-deposit today toward atomic and Token Standard V2"
    >
      <li class="vm-axis__pt">
        <span class="vm-axis__dot" aria-hidden="true"></span>
        <span class="vm-axis__k mono">today</span>
        <span class="vm-axis__v">Most venues managed-deposit</span>
      </li>
      <li class="vm-axis__pt">
        <span class="vm-axis__dot" aria-hidden="true"></span>
        <span class="vm-axis__k mono">adopting</span>
        <span class="vm-axis__v">Atomic allocation, live and widening</span>
      </li>
      <li class="vm-axis__pt vm-axis__pt--target">
        <span class="vm-axis__dot" aria-hidden="true"></span>
        <span class="vm-axis__k mono">rolling out</span>
        <span class="vm-axis__v">CIP-0112, Token Standard V2</span>
      </li>
    </ol>

    <p class="vm__note" data-reveal>
      <span class="vm__note-dot" aria-hidden="true"></span>
      <span>
        Atomic settlement is live on Canton today and is valid only when
        <em>every</em> leg is Mode A, which the router enforces. Most accessible
        venues are still managed-deposit, so the atomic path widens as venues adopt
        the allocation flow. CIP-0112 (Token Standard V2) brings further privacy,
        performance, and settlement improvements, rolling out across the network.
        Quote aggregation works across both modes now.
      </span>
    </p>
  </div>
</section>

<style>
  .vm {
    position: relative;
    padding-top: var(--sp-tight);
    padding-bottom: var(--sp-default);
    overflow: hidden;
  }
  .vm > .container {
    position: relative;
    z-index: 1;
    max-width: 1180px;
  }

  .vm__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    margin-bottom: 40px;
  }
  .vm__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    display: flex;
    flex-direction: column;
  }
  .vm__muted {
    color: var(--ink-display-muted);
  }

  .vm__grid {
    display: grid;
    /* minmax(0, 1fr) so each card can shrink below its content's min-content
       width at narrow widths (a bare 1fr floors at min-content → the card
       overflows its container and the mono chip is clipped). */
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .vm-mode {
    min-width: 0;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  /* Mode A - faint ember border + an ember top-glow over the card's lit glass. */
  .vm-mode--a {
    border-color: var(--ember-soft);
  }
  .vm-mode--a::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(
      120% 60% at 50% 0%,
      var(--ember-glow),
      transparent 58%
    );
  }
  .vm-mode > * {
    position: relative;
    z-index: 1;
  }

  .vm-mode__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .vm-mode__label {
    font-size: 11.5px;
    color: var(--ink-3);
    letter-spacing: 0.02em;
  }
  .vm-badge {
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: var(--r-pill);
    color: var(--ink-3);
    border: 1px solid var(--line-2);
  }
  .vm-badge--on {
    color: var(--ember-hi);
    border-color: var(--ember-soft);
    background: color-mix(in srgb, var(--bg-1) 82%, var(--ember) 18%);
  }

  .vm-mode__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(22px, 2.6vw, 28px);
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .vm-mode__sub {
    font-family: var(--font-ui);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin-top: -2px;
  }

  .vm-rows {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .vm-row {
    display: flex;
    align-items: center;
    gap: 11px;
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--ink);
  }
  .vm-ic {
    width: 16px;
    height: 16px;
    flex: none;
    color: var(--ink-3);
  }
  .vm-row--on .vm-ic {
    color: var(--ember);
  }

  .vm-mode__settles {
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--ink-2);
  }
  .vm-mode__settles .mono {
    color: var(--ink);
  }
  .vm-mode__settles--muted {
    color: var(--ink-3);
  }

  .vm-chip {
    margin-top: 2px;
    padding: 10px 12px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-size: 12px;
    color: var(--ink-3);
    /* Wrap (never force a min-content width that overflows the card at narrow
       widths); break the long quoted value if it can't fit on one line. */
    white-space: normal;
    overflow-wrap: anywhere;
  }
  .vm-chip__val {
    color: var(--ink-2);
  }
  .vm-chip__val--on {
    color: var(--ember);
  }

  /* Maturation axis: three stages connected left (today) to right (target). */
  .vm-axis {
    list-style: none;
    margin: 36px auto 0;
    max-width: 820px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    position: relative;
  }
  .vm-axis::before {
    content: '';
    position: absolute;
    top: 5px;
    left: 12%;
    right: 12%;
    height: 1px;
    background: linear-gradient(90deg, var(--line-2), var(--ember-soft));
  }
  .vm-axis__pt {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-top: 18px;
    text-align: center;
  }
  .vm-axis__dot {
    position: absolute;
    top: 1px;
    left: 50%;
    transform: translateX(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--bg-1);
    border: 1px solid var(--ink-3);
  }
  .vm-axis__pt--target .vm-axis__dot {
    background: var(--ember);
    border-color: var(--ember);
    box-shadow: 0 0 9px 0 var(--ember-soft);
  }
  .vm-axis__k {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-3);
  }
  .vm-axis__pt--target .vm-axis__k {
    color: var(--ember-tx);
  }
  .vm-axis__v {
    font-family: var(--font-ui);
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--ink-2);
  }
  @media (max-width: 560px) {
    .vm-axis {
      grid-template-columns: 1fr;
      gap: 12px;
      text-align: left;
    }
    .vm-axis::before {
      display: none;
    }
    .vm-axis__pt {
      padding: 0 0 0 20px;
      text-align: left;
    }
    .vm-axis__dot {
      left: 2px;
      top: 4px;
    }
  }

  .vm__note {
    display: flex;
    align-items: flex-start;
    gap: 11px;
    max-width: 820px;
    margin: 28px auto 0;
    padding: 16px 18px;
    background: var(--bg-1);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-family: var(--font-ui);
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-2);
  }
  .vm__note em {
    font-style: normal;
    color: var(--ink);
  }
  .vm__note-dot {
    margin-top: 6px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
    flex: none;
  }

  /* Mobile: cards stack 1-col (Mode A first, by source order). */
  @media (max-width: 720px) {
    .vm__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  @media (max-width: 460px) {
    .vm-mode {
      padding: 20px;
    }
  }
</style>
