---
/**
 * SealMark - the Synfin routing-instrument logomark (DESIGN.md §4), drawn in
 * light strokes on dark with an ember center. Concentric rings + a full 48-tick
 * measurement bezel + an inscribed route bezier resolving to the ember
 * settlement dot. Single source → nav logo, favicon, and (via `check`) the
 * "settled" seal-check. 48×48 viewBox, center (24,24).
 */
interface Props {
  size?: number;
  title?: string;
  /** Render the "settled" seal-check (ember check) instead of route + dot. */
  check?: boolean;
  decorative?: boolean;
  class?: string;
}
const {
  size = 28,
  title = 'Synfin seal',
  check = false,
  decorative = false,
  class: className,
} = Astro.props;

const STROKE = 'rgba(241,239,234,0.5)';
const STROKE_DIM = 'rgba(241,239,234,0.28)';
const ROUTE = 'rgba(241,239,234,0.45)';

// 48 radial ticks (4px) around the bezel: r 17.5 → 21.5.
const ticks = Array.from({ length: 48 }, (_, i) => {
  const a = (i * 7.5 * Math.PI) / 180;
  const f = (n: number): number => +n.toFixed(3);
  return {
    x1: f(24 + 17.5 * Math.cos(a)),
    y1: f(24 + 17.5 * Math.sin(a)),
    x2: f(24 + 21.5 * Math.cos(a)),
    y2: f(24 + 21.5 * Math.sin(a)),
  };
});

const a11y = decorative
  ? { 'aria-hidden': 'true' as const }
  : { role: 'img' as const, 'aria-label': title };
---

<svg
  class:list={['seal', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  fill="none"
  {...a11y}
>
  {!decorative && <title>{title}</title>}
  <circle cx="24" cy="24" r="21.5" stroke={STROKE} stroke-width="1"></circle>
  <circle cx="24" cy="24" r="15" stroke={STROKE_DIM} stroke-width="1"></circle>
  <g stroke={STROKE} stroke-width="0.75" stroke-linecap="round">
    {ticks.map((t) => <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} />)}
  </g>

  {
    check ? (
      <path
        class="seal-check"
        d="M17 24.5 L22 29.5 L31 18.5"
        stroke="var(--ember)"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    ) : (
      <Fragment>
        <path
          d="M7 24 C 15 24, 17 15, 24 15 S 33 33, 41 24"
          stroke={ROUTE}
          stroke-width="1.3"
          stroke-linecap="round"
        />
        <circle cx="24" cy="24" r="2.6" fill="var(--ember)" />
      </Fragment>
    )
  }
</svg>

<style>
  .seal {
    display: block;
    flex: none;
  }
</style>
