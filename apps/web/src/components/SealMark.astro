---
/**
 * SealMark — the Synfin logomark (DESIGN.md §4): an engraved seal / precision
 * dial. Concentric rings + a 48-tick radial measurement ring + an inscribed
 * route curve resolving to an oxblood center (the settlement). Single source,
 * reused as the nav logo, section eyebrows, and (via `check`) the "settled"
 * seal-check. The favicon mirrors this geometry in public/favicon.svg.
 *
 * 60×60 viewBox, center (30,30). Strokes use --ink; the center/check use --seal.
 */
interface Props {
  size?: number;
  title?: string;
  /** Render the "settled" seal-check (oxblood check) instead of route + dot. */
  check?: boolean;
  /** Decorative instances are hidden from assistive tech. */
  decorative?: boolean;
  class?: string;
}
const {
  size = 28,
  title = 'Synfin seal',
  check = false,
  decorative = false,
  class: className,
} = Astro.props;

// 48 radial ticks every 7.5°; every 4th (every 30°) is long. r2 = 22.5.
const ticks = Array.from({ length: 48 }, (_, i) => {
  const a = (i * 7.5 * Math.PI) / 180;
  const long = i % 4 === 0;
  const r1 = long ? 17 : 19.5;
  const r2 = 22.5;
  return {
    x1: +(30 + r1 * Math.cos(a)).toFixed(3),
    y1: +(30 + r1 * Math.sin(a)).toFixed(3),
    x2: +(30 + r2 * Math.cos(a)).toFixed(3),
    y2: +(30 + r2 * Math.sin(a)).toFixed(3),
    w: long ? 1 : 0.6,
    o: long ? 0.85 : 0.45,
  };
});

const a11y = decorative
  ? { 'aria-hidden': 'true' as const }
  : { role: 'img' as const, 'aria-label': title };
---

<svg
  class:list={['seal', className]}
  width={size}
  height={size}
  viewBox="0 0 60 60"
  fill="none"
  {...a11y}
>
  {!decorative && <title>{title}</title>}
  <!-- rings -->
  <circle cx="30" cy="30" r="26" stroke="var(--ink)" stroke-width="1.2"
  ></circle>
  <circle
    cx="30"
    cy="30"
    r="21"
    stroke="var(--ink)"
    stroke-width="0.7"
    opacity="0.5"></circle>
  <!-- 48 radial measurement ticks -->
  <g stroke="var(--ink)" stroke-linecap="round">
    {
      ticks.map((t) => (
        <line
          x1={t.x1}
          y1={t.y1}
          x2={t.x2}
          y2={t.y2}
          stroke-width={t.w}
          opacity={t.o}
        />
      ))
    }
  </g>

  {
    check ? (
      <path
        class="seal-check"
        d="M22 30.5 L28 36.5 L40 23.5"
        stroke="var(--seal)"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    ) : (
      <Fragment>
        {/* inscribed route, resolving to the settlement dot */}
        <path
          d="M7 30 C 14 30, 16 22, 23 22 S 33 38, 30 30"
          stroke="var(--ink)"
          stroke-width="1.3"
          stroke-linecap="round"
        />
        <circle cx="30" cy="30" r="3.2" fill="var(--seal)" />
      </Fragment>
    )
  }
</svg>

<style>
  .seal {
    display: block;
    flex: none;
  }
</style>
