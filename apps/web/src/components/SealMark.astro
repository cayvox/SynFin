---
/**
 * SealMark - the Synfin orbit mark: two broken fog arcs (the orbits), an ember
 * route line resolving to the ember node, with an optional soft ember glow.
 * Single source for the four in-page usages (hero core, Open, ProofBento, and
 * the RouterCard "settled" seal). 64x64 viewBox, center (32,32). Colors are the
 * site tokens (ember + fog), so the whole mark re-themes from one place.
 *
 * Variants (API preserved):
 *   glow  (default true)  the faint ember halo behind the node; set false for a
 *                         flat mark.
 *   check (default false) the "settled" state: adds a thin ember seal ring around
 *                         the node. This replaces the old ember checkmark and
 *                         reads as "settled" without animation (the previous
 *                         seal-check was also static; there was no animation contract).
 */
interface Props {
  size?: number;
  title?: string;
  /** "Settled" state: ring the ember node as a settlement seal. */
  check?: boolean;
  /** Soft ember halo behind the node (default on). */
  glow?: boolean;
  decorative?: boolean;
  class?: string;
}
const {
  size = 28,
  title = 'Synfin seal',
  check = false,
  glow = true,
  decorative = false,
  class: className,
} = Astro.props;

const FOG = 'var(--ink-3)'; // #8b887f
const EMBER = 'var(--ember)';

const a11y = decorative
  ? { 'aria-hidden': 'true' as const }
  : { role: 'img' as const, 'aria-label': title };
---

<svg
  class:list={['seal', className]}
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  {...a11y}
>
  {!decorative && <title>{title}</title>}

  {
    glow && (
      <Fragment>
        <circle cx="32" cy="32" r="8.6" fill={EMBER} opacity="0.1" />
        <circle cx="32" cy="32" r="6" fill={EMBER} opacity="0.16" />
      </Fragment>
    )
  }

  <path
    d="M 21 32 A 11 11 0 1 1 32 43"
    fill="none"
    stroke={FOG}
    stroke-width="1.9"
    stroke-linecap="round"></path>
  <path
    d="M 49 32 A 17 17 0 1 1 32 15"
    fill="none"
    stroke={FOG}
    stroke-width="1.9"
    stroke-linecap="round"
    opacity="0.8"></path>
  <path
    d="M 32 32 L 51 26"
    fill="none"
    stroke={EMBER}
    stroke-width="2.8"
    stroke-linecap="round"></path>

  {
    check && (
      <circle
        class="seal-ring"
        cx="32"
        cy="32"
        r="7.6"
        fill="none"
        stroke={EMBER}
        stroke-width="1.4"
        opacity="0.85"
      />
    )
  }

  <circle cx="32" cy="32" r="4.4" fill={EMBER}></circle>
</svg>

<style>
  .seal {
    display: block;
    flex: none;
  }
</style>
