---
/**
 * §4 "Per-leg privacy" (CONTENT.md §5; DESIGN.md §8b.4) - a 2-column editorial
 * split: left, the words; right, an interactive diagram of the atomic
 * transaction from a single VENUE's point of view.
 *
 * The executor (Synfin coordinator) and the taker see the whole route; each
 * venue sees only its own leg and is sealed from the others. The diagram makes
 * that point interactive: one venue is "viewing" at a time (OneSwap by default);
 * its leg is visible with real mono data, every other leg is redacted. Hovering
 * or focusing a venue switches the point of view. All numbers come from the
 * large-order snapshot in src/data/market.ts. Illustrative, never measured.
 */
import Eyebrow from './Eyebrow.astro';
import {
  legs,
  largeTotalOut,
  LARGE_SELL_CC,
  best,
  BASE,
  QUOTE,
  fmtAmount,
  fmtPrice,
} from '../data/market.ts';
---

<section id="privacy" class="pv" aria-labelledby="privacy-title">
  <div class="container">
    <div class="pv__grid">
      <header class="pv__copy" data-reveal>
        <Eyebrow text="Privacy" />
        <h2 class="pv__title" id="privacy-title">
          <span>Each venue sees</span>
          <span class="pv__muted">only its own leg.</span>
        </h2>
        <p class="pv__lead">
          Synfin settles the split so every venue verifies and executes only its
          own leg. The executor coordinates the whole atomic transaction, and no
          venue sees the others.
        </p>
        <p class="pv__body">
          With no public mempool, there is nothing to front-run.
        </p>
        <p class="pv__caveat">
          Per-leg privacy is not anonymity to your own counterparty. A venue
          does not see <em>other</em> venues’ legs, but it does see its own.
        </p>
      </header>

      <div class="pv__diagram card" data-reveal data-pv data-active={best.name}>
        <!-- Executor: sees the whole route -->
        <div class="pv-exec">
          <span class="pv-exec__seal" aria-hidden="true"></span>
          <div class="pv-exec__id">
            <span class="pv-exec__name">Executor: Synfin coordinator</span>
            <span class="pv-exec__sub"
              >submits one atomic transaction · sees the whole route</span
            >
          </div>
          <span class="pv-exec__tag mono"
            >{fmtAmount(LARGE_SELL_CC)}
            {BASE} → {fmtAmount(largeTotalOut)}
            {QUOTE}</span
          >
        </div>

        <p class="pv__hint mono" aria-hidden="true">
          Viewing as <span class="pv-active">{best.name}</span>. Hover a venue
          to switch.
        </p>

        <ul class="pv-lanes">
          {
            legs.map((leg) => (
              <li
                class:list={['pv-lane', leg.best && 'is-active']}
                data-venue={leg.name}
                tabindex="0"
                aria-label={`${leg.name} leg: share ${Math.round(leg.sharePct)} percent, ${fmtAmount(leg.inCC)} ${BASE} in, ${fmtAmount(leg.outUSDCx)} ${QUOTE} out at ${fmtPrice(leg.price)}. Sealed from the other venues.`}
              >
                <span class="pv-lane__node" aria-hidden="true" />
                <div class="pv-lane__main">
                  <div class="pv-lane__head">
                    <span class="pv-lane__name">{leg.name}</span>
                    <span class="pv-lane__state pv-lane__state--on mono">
                      this venue
                    </span>
                    <span class="pv-lane__state pv-lane__state--off mono">
                      sealed
                    </span>
                  </div>

                  <dl class="pv-data" aria-hidden="true">
                    <div class="pv-data__row">
                      <dt>share</dt>
                      <dd class="mono pv-data__em">
                        {Math.round(leg.sharePct)}%
                      </dd>
                    </div>
                    <div class="pv-data__row">
                      <dt>in</dt>
                      <dd class="mono">
                        {fmtAmount(leg.inCC)} {BASE}
                      </dd>
                    </div>
                    <div class="pv-data__row">
                      <dt>out</dt>
                      <dd class="mono">
                        {fmtAmount(leg.outUSDCx)} {QUOTE}
                      </dd>
                    </div>
                    <div class="pv-data__row">
                      <dt>price</dt>
                      <dd class="mono">{fmtPrice(leg.price)}</dd>
                    </div>
                  </dl>

                  <div class="pv-redact" aria-hidden="true">
                    <span class="pv-redact__bar" style="width:64%" />
                    <span class="pv-redact__bar" style="width:88%" />
                    <span class="pv-redact__bar" style="width:46%" />
                  </div>

                  <div class="pv-lane__foot mono">
                    <span class="pv-lane__foot--on">
                      <span class="pv-dot" aria-hidden="true" /> sees only its
                      own leg
                    </span>
                    <span class="pv-lane__foot--off">
                      sealed from <span class="pv-active">{best.name}</span>
                    </span>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>

        <p class="pv__demo mono">
          Illustrative example. Not live or measured data.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .pv {
    position: relative;
    padding-top: var(--sp-tight);
    padding-bottom: var(--sp-default);
    overflow: hidden;
  }
  .pv > .container {
    position: relative;
    z-index: 1;
  }
  .pv__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1fr);
    gap: 56px;
    align-items: center;
  }
  .pv__copy,
  .pv__diagram {
    min-width: 0;
  }

  /* Left copy */
  .pv__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin-top: 22px;
    display: flex;
    flex-direction: column;
  }
  .pv__muted {
    color: var(--ink-display-muted);
  }
  .pv__lead {
    margin-top: 24px;
    max-width: 44ch;
    font-size: 16.5px;
    line-height: 1.6;
    color: var(--ink-2);
  }
  .pv__body {
    margin-top: 16px;
    max-width: 44ch;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-2);
  }
  .pv__caveat em {
    font-style: normal;
    color: var(--ink);
  }
  .pv__caveat {
    margin-top: 26px;
    padding-left: 16px;
    border-left: 1px solid var(--line-2);
    max-width: 46ch;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--ink-3);
  }

  /* Right diagram */
  .pv__diagram {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .pv-exec {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px 12px;
    padding: 13px 15px;
    border-radius: var(--r-sm);
    border: 1px solid var(--ember-soft);
    background: color-mix(in srgb, var(--bg-2) 86%, var(--ember) 14%);
  }
  .pv-exec__seal {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 9px 0 var(--ember-soft);
    flex: none;
  }
  .pv-exec__id {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .pv-exec__name {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 13.5px;
    color: var(--ink);
  }
  .pv-exec__sub {
    font-family: var(--font-ui);
    font-size: 11.5px;
    color: var(--ink-3);
  }
  .pv-exec__tag {
    margin-left: auto;
    flex: none;
    font-size: 11.5px;
    color: var(--ember-hi);
    white-space: nowrap;
  }

  .pv__hint {
    font-size: 11px;
    color: var(--ink-3);
    margin: -2px 0 0;
  }
  .pv__hint .pv-active {
    color: var(--ember-tx);
  }

  /* Lanes: a vertical list with a left spine; one venue active at a time. */
  .pv-lanes {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pv-lane {
    position: relative;
    padding: 12px 14px 12px 30px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    cursor: default;
    transition:
      border-color 0.3s ease,
      background 0.3s ease;
  }
  .pv-lane:focus-visible {
    outline: 2px solid var(--ember);
    outline-offset: 2px;
  }
  /* Left spine node, ember when active. */
  .pv-lane__node {
    position: absolute;
    left: 13px;
    top: 18px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid var(--ink-3);
    background: var(--bg-1);
    transition:
      border-color 0.3s ease,
      background 0.3s ease,
      box-shadow 0.3s ease;
  }
  .pv-lane.is-active {
    border-color: var(--ember-soft);
    background: color-mix(in srgb, var(--bg-2) 92%, var(--ember) 8%);
  }
  .pv-lane.is-active .pv-lane__node {
    border-color: var(--ember);
    background: var(--ember);
    box-shadow: 0 0 9px 0 var(--ember-soft);
  }

  .pv-lane__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .pv-lane__name {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 13px;
    color: var(--ink);
  }
  .pv-lane__state {
    font-size: 10.5px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }
  .pv-lane__state--on {
    color: var(--ember-tx);
    display: none;
  }
  .pv-lane__state--off {
    color: var(--ink-3);
  }
  .pv-lane.is-active .pv-lane__state--on {
    display: inline;
  }
  .pv-lane.is-active .pv-lane__state--off {
    display: none;
  }

  /* Body: data when active, redaction when sealed. Reserve height so the swap
     does not jump the layout. */
  .pv-data,
  .pv-redact {
    margin: 10px 0 0;
    min-height: 96px;
  }
  .pv-data {
    display: none;
    flex-direction: column;
    gap: 6px;
  }
  .pv-redact {
    display: flex;
    flex-direction: column;
    gap: 9px;
    justify-content: center;
  }
  .pv-lane.is-active .pv-data {
    display: flex;
  }
  .pv-lane.is-active .pv-redact {
    display: none;
  }
  .pv-data__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 10px;
  }
  .pv-data__row dt {
    font-family: var(--font-ui);
    font-size: 11.5px;
    color: var(--ink-3);
  }
  .pv-data__row dd {
    margin: 0;
    font-size: 12.5px;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .pv-data__row dd.pv-data__em {
    color: var(--ember-tx);
  }
  .pv-redact__bar {
    height: 9px;
    border-radius: 2px;
    background: repeating-linear-gradient(
      -45deg,
      rgba(241, 239, 234, 0.1),
      rgba(241, 239, 234, 0.1) 2px,
      transparent 2px,
      transparent 6px
    );
    border: 1px solid var(--line);
  }

  .pv-lane__foot {
    margin-top: 10px;
    font-size: 10.5px;
    letter-spacing: 0.01em;
  }
  .pv-lane__foot--on {
    display: none;
    align-items: center;
    gap: 6px;
    color: var(--ember-hi);
  }
  .pv-lane__foot--off {
    color: var(--ink-3);
  }
  .pv-lane.is-active .pv-lane__foot--on {
    display: inline-flex;
  }
  .pv-lane.is-active .pv-lane__foot--off {
    display: none;
  }
  .pv-active {
    color: var(--ink-2);
  }
  .pv-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 7px 0 var(--ember-soft);
    flex: none;
  }

  .pv__demo {
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--ink-3);
  }

  @media (prefers-reduced-motion: reduce) {
    .pv-lane,
    .pv-lane__node {
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .pv__grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 40px;
    }
    .pv__lead,
    .pv__body,
    .pv__caveat {
      max-width: none;
    }
  }
</style>

<script>
  // Per-leg privacy: one venue "views" at a time. Hover or focus a lane to make
  // that venue the viewer (its leg visible, the rest sealed). Default is the
  // best venue, set server-side, so no-JS and reduced-motion render a correct
  // static state. User-initiated only; no timers, no motion.
  const diagram = document.querySelector<HTMLElement>('[data-pv]');
  if (diagram) {
    const lanes = Array.from(diagram.querySelectorAll<HTMLElement>('.pv-lane'));
    const names = Array.from(
      diagram.querySelectorAll<HTMLElement>('.pv-active'),
    );
    const fallback = diagram.dataset.active ?? '';

    const view = (venue: string): void => {
      diagram.dataset.active = venue;
      for (const l of lanes)
        l.classList.toggle('is-active', l.dataset.venue === venue);
      for (const n of names) n.textContent = venue;
    };

    for (const lane of lanes) {
      const venue = lane.dataset.venue ?? '';
      lane.addEventListener('pointerenter', () => view(venue));
      lane.addEventListener('focusin', () => view(venue));
    }
    diagram.addEventListener('pointerleave', () => view(fallback));
  }
</script>
