---
/**
 * Nav (DESIGN.md §5) — logo left; a centered dark-glass pill of links
 * (Overview · How it works · Proof · Open & neutral · | · Spec ↗); right:
 * GitHub + primary "Read the spec". Mobile collapses the pill into a no-JS
 * <details> Menu. In-page links resolve to sections 2–9 as they land.
 */
import SealMark from './SealMark.astro';
import Button from './Button.astro';
import { REPO, SPEC } from '../site.ts';

const links = [
  { label: 'Overview', href: '#main' },
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Proof', href: '#proof' },
  { label: 'Open & neutral', href: '#open' },
];
---

<header class="nav">
  <div class="container nav__inner">
    <a class="brand" href="/" aria-label="Synfin — home">
      <SealMark size={28} decorative />
      <span class="brand__word">Synfin</span>
    </a>

    <nav class="pill" aria-label="Primary">
      {
        links.map((l) => (
          <a class="pill__link" href={l.href}>
            {l.label}
          </a>
        ))
      }
      <span class="pill__divider" aria-hidden="true"></span>
      <a
        class="pill__link"
        href={SPEC}
        target="_blank"
        rel="noopener noreferrer">Spec ↗</a
      >
    </nav>

    <div class="nav__right">
      <a
        class="nav__ghost"
        href={REPO}
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      <Button
        variant="primary"
        href={SPEC}
        target="_blank"
        rel="noopener noreferrer">Read the spec</Button
      >
    </div>

    <details class="nav__menu">
      <summary aria-label="Menu">Menu</summary>
      <div class="nav__menu-panel">
        {
          links.map((l) => (
            <a class="pill__link" href={l.href}>
              {l.label}
            </a>
          ))
        }
        <a
          class="pill__link"
          href={REPO}
          target="_blank"
          rel="noopener noreferrer">GitHub ↗</a
        >
        <Button
          variant="primary"
          href={SPEC}
          target="_blank"
          rel="noopener noreferrer"
          block>Read the spec</Button
        >
      </div>
    </details>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    padding-block: 16px;
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .brand__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 19px;
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  /* Centered dark-glass pill */
  .pill {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px;
    background: rgba(20, 21, 25, 0.66);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    backdrop-filter: blur(14px);
  }
  /* Without the blur the translucent pill must read on its own — make it solid. */
  @media (prefers-reduced-transparency: reduce) {
    .pill {
      background: #14151a;
    }
  }
  .pill__link {
    padding: 7px 13px;
    border-radius: var(--r-pill);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 13.5px;
    color: var(--ink-2);
    transition:
      color var(--d-fast) var(--e-out),
      background var(--d-fast) var(--e-out);
  }
  .pill__link:hover {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.05);
  }
  .pill__divider {
    width: 1px;
    height: 18px;
    margin-inline: 4px;
    background: var(--line-2);
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .nav__ghost {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 13.5px;
    color: var(--ink-2);
    transition: color var(--d-fast) var(--e-out);
  }
  .nav__ghost:hover {
    color: var(--ink);
  }

  /* Mobile menu */
  .nav__menu {
    display: none;
  }
  .nav__menu > summary {
    list-style: none;
    cursor: pointer;
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 13.5px;
    padding: 8px 14px;
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    color: var(--ink);
  }
  .nav__menu > summary::-webkit-details-marker {
    display: none;
  }
  .nav__menu-panel {
    position: absolute;
    left: 16px;
    right: 16px;
    margin-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 14px;
    background: rgba(18, 19, 22, 0.96);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    box-shadow: var(--card-shadow);
    backdrop-filter: blur(14px);
  }

  @media (max-width: 860px) {
    .pill,
    .nav__right {
      display: none;
    }
    .nav__menu {
      display: block;
    }
  }
</style>
