---
/**
 * §7 "For the ecosystem" (CONTENT.md §8; DESIGN.md §8b.7) - a centered trio of
 * lit-glass audience cards (Venues · Wallets & apps · Institutions), each with a
 * rounded lit icon tile, a Display-M title, a short body with one bold key
 * phrase, and a mono meta line (ember dot) above a hairline. Closes with the
 * honest Canton-context line. Ember is restrained to the three meta dots.
 */
import Eyebrow from './Eyebrow.astro';

const cards = [
  {
    icon: 'venue',
    title: 'Venues',
    body: [
      { t: 'Implement ', em: false },
      { t: 'one adapter', em: true },
      {
        t: ' and become reachable through every Synfin integration. More flow, no new counterparties to chase.',
        em: false,
      },
    ],
    meta: 'one adapter, every integration',
  },
  {
    icon: 'wallet',
    title: 'Wallets & apps',
    body: [
      { t: 'One SDK', em: true },
      {
        t: ' for best-execution swaps across all of Canton’s liquidity. Drop it in and route every trade to the best price.',
        em: false,
      },
    ],
    meta: 'one SDK, all of Canton',
  },
  {
    icon: 'institution',
    title: 'Institutions',
    body: [
      { t: 'Best execution', em: true },
      {
        t: ' with settlement atomicity and per-leg confidentiality, provable to the basis point, on neutral open infrastructure.',
        em: false,
      },
    ],
    meta: 'provable best-ex, per-leg private',
  },
];
---

<section id="ecosystem" class="eco" aria-labelledby="ecosystem-title">
  <div class="container">
    <header class="eco__head" data-reveal>
      <Eyebrow text="Who it's for" />
      <h2 class="eco__title" id="ecosystem-title">
        <span>Built for everyone</span>
        <span class="eco__muted">routing on Canton.</span>
      </h2>
    </header>

    <div class="eco__grid">
      {
        cards.map((c, i) => (
          <article class="eco-card card" data-reveal>
            <div class="eco-card__top">
              <span class="eco-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  {c.icon === 'venue' && (
                    <>
                      <path
                        d="M4 20V7l6-3 6 3v13"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M16 20V10l4 2v8M3 20h18"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M8.5 11h3M8.5 14.5h3"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                      />
                    </>
                  )}
                  {c.icon === 'wallet' && (
                    <>
                      <rect
                        x="3"
                        y="6"
                        width="18"
                        height="13"
                        rx="2.5"
                        stroke="currentColor"
                        stroke-width="1.4"
                      />
                      <path
                        d="M3 9.5h18"
                        stroke="currentColor"
                        stroke-width="1.4"
                      />
                      <circle cx="16.5" cy="13.5" r="1.4" fill="currentColor" />
                    </>
                  )}
                  {c.icon === 'institution' && (
                    <>
                      <path
                        d="M3.5 9.5L12 4l8.5 5.5"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                      <path
                        d="M5.5 10v8M10 10v8M14 10v8M18.5 10v8"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                      />
                      <path
                        d="M3.5 20.5h17"
                        stroke="currentColor"
                        stroke-width="1.4"
                        stroke-linecap="round"
                      />
                    </>
                  )}
                </svg>
              </span>
              <span class="eco-card__index mono">
                {String(i + 1).padStart(2, '0')}
              </span>
            </div>
            <h3 class="eco-card__title">{c.title}</h3>
            <p class="eco-card__body">
              {c.body.map((seg) =>
                seg.em ? <strong>{seg.t}</strong> : <span>{seg.t}</span>,
              )}
            </p>
            <p class="eco-card__meta mono">
              <span class="eco-card__bar" aria-hidden="true" />
              {c.meta}
            </p>
          </article>
        ))
      }
    </div>

    <p class="eco__context" data-reveal>
      Canton is where regulated, institutional liquidity is moving on-chain, on
      a common token standard. Synfin is the neutral best-execution layer on top
      of it.
    </p>
  </div>
</section>

<style>
  .eco {
    position: relative;
    padding-top: var(--sp-tight);
    padding-bottom: var(--sp-default);
    overflow: hidden;
  }
  .eco > .container {
    position: relative;
    z-index: 1;
    max-width: 1180px;
  }

  .eco__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    text-align: center;
    margin-bottom: 40px;
  }
  .eco__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 52px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    display: flex;
    flex-direction: column;
  }
  .eco__muted {
    color: var(--ink-display-muted);
  }

  .eco__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }

  .eco-card {
    min-width: 0;
    padding: 26px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .eco-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .eco-card__index {
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--ink-3);
  }
  .eco-card__icon {
    width: 44px;
    height: 44px;
    border-radius: var(--r-sm);
    display: grid;
    place-items: center;
    color: var(--ink);
    background: radial-gradient(
      120% 100% at 50% 0%,
      rgba(241, 239, 234, 0.1),
      var(--bg-2)
    );
    border: 1px solid var(--line-2);
    transition: border-color var(--d-hover) var(--e-hover);
  }
  /* §17 - the icon tile warms when its card lifts. */
  .eco-card:hover .eco-card__icon {
    border-color: var(--ember-soft);
  }
  .eco-card__icon svg {
    width: 22px;
    height: 22px;
  }
  .eco-card__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(20px, 2.4vw, 26px);
    letter-spacing: -0.015em;
    color: var(--ink);
  }
  .eco-card__body {
    font-family: var(--font-ui);
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-2);
  }
  .eco-card__body strong {
    font-weight: 500;
    color: var(--ink);
  }
  .eco-card__meta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 2px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
    font-size: 11.5px;
    letter-spacing: 0.01em;
    color: var(--ink-2);
    overflow-wrap: anywhere;
  }
  .eco-card__bar {
    width: 16px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--ember), var(--ember-soft));
    box-shadow: 0 0 8px -1px var(--ember-soft);
    flex: none;
  }

  .eco__context {
    max-width: 64ch;
    margin: 36px auto 0;
    text-align: center;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-3);
  }

  /* Tablet: 3 → 2 (third wraps), then 1-col on mobile. */
  @media (max-width: 900px) {
    .eco__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 620px) {
    .eco__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
  @media (max-width: 460px) {
    .eco-card {
      padding: 20px;
    }
  }
</style>
