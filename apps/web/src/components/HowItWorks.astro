---
/**
 * §3 "How it works" (CONTENT.md §3; DESIGN.md §12) - a 2-column editorial split:
 * left, the words (tonal heading + intro + a 4-row step list, "Route & settle"
 * active in ember); right, the router Orbital. Reads as: scan every venue →
 * lock the best route (46/33/21) → settle atomically → +47.8 bps edge.
 */
import Eyebrow from './Eyebrow.astro';
import Orbital from './Orbital.astro';

const steps = [
  { n: '01', t: 'Quote', d: 'pull live prices from every venue', on: false },
  {
    n: '02',
    t: 'Compare',
    d: 'find the best execution across all of them',
    on: false,
  },
  {
    n: '03',
    t: 'Split',
    d: 'route the order to the venues that fill it best',
    on: false,
  },
  {
    n: '04',
    t: 'Route & settle',
    d: 'execute the split as one atomic, private transaction',
    on: true,
  },
];
---

<section id="how-it-works" class="how" aria-labelledby="how-title">
  <div class="how__grid">
    <div class="how__copy" data-reveal>
      <Eyebrow text="How it works" />
      <h2 class="how__title" id="how-title">
        <span>One call.</span>
        <span class="how__muted">The whole market.</span>
      </h2>
      <p class="how__intro">
        Tell Synfin what you want to trade. It quotes every venue, splits your
        order for the best price, and settles the whole thing in one
        transaction.
      </p>
      <ol class="how__steps">
        {
          steps.map((s) => (
            <li class:list={['how__step', s.on && 'how__step--on']}>
              <span class="how__marker" aria-hidden="true">
                <span class="how__node mono">{s.n}</span>
              </span>
              <div class="how__stepbody">
                <div class="how__st">{s.t}</div>
                <div class="how__sd">{s.d}</div>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <div class="how__orb" data-reveal>
      <Orbital />
    </div>
  </div>
</section>

<style>
  .how {
    position: relative;
    padding-top: var(--sp-act);
    padding-bottom: var(--sp-default);
    overflow: hidden;
  }
  .how__grid {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: grid;
    /* minmax(0, …) so neither column floors at min-content at narrow widths. */
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
    gap: 40px;
    align-items: center;
  }
  .how__copy,
  .how__orb {
    min-width: 0;
  }

  .how__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(32px, 4.6vw, 50px);
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin-top: 22px;
    display: flex;
    flex-direction: column;
  }
  .how__muted {
    color: var(--ink-display-muted);
  }
  .how__intro {
    margin-top: 24px;
    max-width: 42ch;
    font-size: 16.5px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* The four steps as a connected routing pipeline: indexed nodes on a rail,
     the final "Route & settle" node lit in ember (the locked best route). */
  .how__steps {
    margin-top: 36px;
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .how__step {
    position: relative;
    display: grid;
    grid-template-columns: 28px minmax(0, 1fr);
    gap: 16px;
    padding-bottom: 26px;
  }
  .how__step:last-child {
    padding-bottom: 0;
  }
  .how__marker {
    position: relative;
    display: flex;
    justify-content: center;
  }
  /* The rail segment connecting one node to the next. */
  .how__step:not(:last-child) .how__marker::after {
    content: '';
    position: absolute;
    top: 30px;
    bottom: -30px;
    left: 50%;
    width: 1px;
    transform: translateX(-50%);
    background: var(--line);
  }
  .how__node {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--line-2);
    background: var(--bg-1);
    display: grid;
    place-items: center;
    font-size: 11px;
    color: var(--ink-3);
  }
  .how__step--on .how__node {
    border-color: var(--ember-soft);
    color: var(--ember);
    box-shadow:
      0 0 0 4px var(--ember-glow),
      0 0 14px -2px var(--ember-soft);
  }
  .how__stepbody {
    padding-top: 4px;
  }
  .how__st {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .how__step--on .how__st {
    color: var(--ember);
  }
  .how__sd {
    margin-top: 3px;
    font-size: 13.5px;
    line-height: 1.45;
    color: var(--ink-2);
  }

  .how__orb {
    display: grid;
    place-items: center;
  }

  /* Tablet: stack - copy on top, orbital centered below, scaled. */
  @media (max-width: 960px) {
    .how__grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 48px;
    }
    .how__orb :global(.orb) {
      width: min(420px, 86vw);
    }
  }

  /* Mobile: simplify the orbital (drop the faint scanned lines), keep core +
     route venues + meter readable. */
  @media (max-width: 560px) {
    .how__orb :global(.orb-scan) {
      display: none;
    }
    .how__orb :global(.vn__q) {
      font-size: 10px;
    }
  }
</style>
