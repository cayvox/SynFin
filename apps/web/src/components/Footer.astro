---
/**
 * Footer (CONTENT.md §9). Hairline top border; quiet. Seal + stewardship on the
 * left, link row, contact + licence on the right.
 */
import SealMark from './SealMark.astro';
import { REPO, SPEC, DOCS, NPM, CAYVOX, EMAIL } from '../site.ts';

const links = [
  { label: 'Specification', href: SPEC, external: true },
  { label: 'GitHub', href: REPO, external: true },
  { label: 'npm', href: NPM, external: true },
  { label: 'Docs', href: DOCS, external: true },
  { label: 'Cayvox', href: CAYVOX, external: true },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <SealMark size={26} decorative />
      <span class="footer__name">Synfin</span>
      <span class="footer__steward">stewarded by Cayvox Labs</span>
    </div>

    <nav class="footer__links" aria-label="Footer">
      {
        links.map((l) => (
          <a
            class="footer__link"
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="footer__meta mono">
      <a class="footer__link" href={`mailto:${EMAIL}`}>{EMAIL}</a>
      <span aria-hidden="true">·</span>
      <span>Open · Apache-2.0</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: var(--hairline) solid var(--line);
    padding-block: var(--s-9);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5) var(--s-7);
  }
  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
  }
  .footer__name {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-weight: 500;
    font-size: var(--t-5);
  }
  .footer__steward {
    font-family: var(--font-ui);
    font-size: var(--t-2);
    color: var(--ink-3);
  }
  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
  }
  .footer__link {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: var(--t-3);
    color: var(--ink-2);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer__link:hover {
    color: var(--ink);
  }
  .footer__meta {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    font-size: var(--t-2);
    color: var(--ink-3);
  }
  .footer__meta .footer__link {
    font-family: var(--font-mono);
    font-size: var(--t-2);
  }
  @media (max-width: 760px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
