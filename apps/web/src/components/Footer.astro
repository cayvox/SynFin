---
/**
 * Footer (CONTENT.md §9) — dark. Seal + stewardship, link row, contact + licence.
 */
import SealMark from './SealMark.astro';
import { REPO, SPEC, DOCS, NPM, CAYVOX, EMAIL } from '../site.ts';

const links = [
  { label: 'Specification', href: SPEC },
  { label: 'GitHub', href: REPO },
  { label: 'npm', href: NPM },
  { label: 'Docs', href: DOCS },
  { label: 'Cayvox', href: CAYVOX },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <SealMark size={24} decorative />
      <span class="footer__name">Synfin</span>
      <span class="footer__steward">stewarded by Cayvox Labs</span>
    </div>

    <nav class="footer__links" aria-label="Footer">
      {
        links.map((l) => (
          <a
            class="footer__link"
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="footer__meta mono">
      <a class="footer__link" href={`mailto:${EMAIL}`}>{EMAIL}</a>
      <span aria-hidden="true">·</span>
      <span>Open · Apache-2.0</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding-block: 40px;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px 32px;
  }
  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }
  .footer__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 16px;
    color: var(--ink);
  }
  .footer__steward {
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--ink-3);
  }
  .footer__links {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
  }
  .footer__link {
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 14px;
    color: var(--ink-2);
    transition: color var(--d-fast) var(--e-out);
  }
  .footer__link:hover {
    color: var(--ink);
  }
  .footer__meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12.5px;
    color: var(--ink-3);
  }
  .footer__meta .footer__link {
    font-family: var(--font-mono);
    font-size: 12.5px;
  }
  @media (max-width: 760px) {
    .footer__inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
