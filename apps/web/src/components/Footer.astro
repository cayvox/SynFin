---
/**
 * Footer (DESIGN.md §15; CONTENT.md §9; reference/synfin-footer.png) - the rich
 * site footer that replaces the earlier simple row. A top hairline + quiet
 * atmosphere (cool wash top-left, faint ember bottom-right); a 3-col grid (brand
 * + Protocol + More); and a bottom bar (copyright/contact · licence chips).
 * STRICT single accent: ember is the only colour anywhere here - the brand meta
 * dot and the "Open source" chip; everything else is warm-grey monochrome.
 */
import { REPO, SPEC, DOCS, NPM, CAYVOX, EMAIL } from '../site.ts';

const protocol = [
  { label: 'Specification', href: SPEC, ext: true },
  { label: 'GitHub', href: REPO, ext: true },
  { label: 'npm', href: NPM, ext: true },
  { label: 'Documentation', href: DOCS, ext: true },
];
const more = [
  { label: 'Open & neutral', href: '#open', ext: false },
  { label: 'How it works', href: '#how-it-works', ext: false },
  { label: 'Cayvox Labs', href: CAYVOX, ext: true },
  { label: 'Contact', href: `mailto:${EMAIL}`, ext: false },
];
const cols = [
  { title: 'Protocol', links: protocol },
  { title: 'More', links: more },
];
---

<footer class="footer">
  <div class="footer__wrap" data-reveal>
    <div class="footer__brand">
      <span class="footer__row">
        <img
          class="footer__mark"
          src="/mark-flat.svg"
          alt=""
          width="28"
          height="28"
          aria-hidden="true"
        />
        <span class="footer__word">Synfin</span>
      </span>
      <p class="footer__by">
        The open, neutral best-execution layer for Canton.
        <b>Stewarded by Cayvox Labs.</b>
      </p>
      <p class="footer__meta mono">
        <span class="footer__meta-dot" aria-hidden="true"></span>
        built on CIP-0056 / 0112 · atomic, on-ledger settlement
      </p>
    </div>

    {
      cols.map((col) => (
        <nav class="footer__col" aria-label={col.title}>
          <h2 class="footer__h mono">{col.title}</h2>
          {col.links.map((l) => (
            <a
              class="footer__link"
              href={l.href}
              {...(l.ext
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
            >
              {l.label}
              {l.ext && (
                <span class="footer__ar" aria-hidden="true">
                  ↗
                </span>
              )}
            </a>
          ))}
        </nav>
      ))
    }
  </div>

  <div class="footer__bar" data-reveal>
    <p class="footer__copy mono">
      <span>© 2026 Cayvox Labs</span>
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
    </p>
    <div class="footer__chips">
      <span class="footer__chip mono">Apache-2.0</span>
      <span class="footer__chip footer__chip--on mono">Open source</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    margin-top: clamp(48px, 7vw, 64px);
    border-top: 1px solid var(--line);
    overflow: hidden;
  }
  .footer__wrap {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin-inline: auto;
    padding: clamp(40px, 6vw, 54px) var(--gutter) 30px;
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 40px;
  }
  .footer__brand,
  .footer__col {
    min-width: 0;
  }
  /* Column = stacked links (each inline-flex link is a flex item on its own row,
     content-width, so the ↗ stays inline but links don't run together). */
  .footer__col {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer__row {
    display: inline-flex;
    align-items: center;
    gap: 11px;
  }
  .footer__mark {
    display: block;
    flex: none;
  }
  .footer__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 20px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .footer__by {
    margin-top: 14px;
    max-width: 34ch;
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-2);
  }
  .footer__by b {
    color: var(--ink);
    font-weight: 500;
  }
  .footer__meta {
    margin-top: 16px;
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 11.5px;
    color: var(--ink-3);
    overflow-wrap: anywhere;
  }
  .footer__meta-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 1px var(--ember-soft);
    flex: none;
  }

  .footer__h {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 16px;
  }
  .footer__link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 0;
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--ink-2);
    transition: color var(--d-hover) var(--e-hover);
  }
  /* §17 - ember underline slides 0→100% from the left on hover. */
  .footer__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 5px;
    height: 1px;
    width: 0;
    background: var(--ember);
    transition: width var(--d-hover) var(--e-hover);
  }
  .footer__link:hover {
    color: var(--ink);
  }
  .footer__link:hover::after {
    width: 100%;
  }
  .footer__ar {
    font-size: 12px;
    color: var(--ink-3);
    transition:
      transform var(--d-hover) var(--e-hover),
      color var(--d-hover) var(--e-hover);
  }
  .footer__link:hover .footer__ar {
    transform: translate(2px, -2px);
    color: var(--ember);
  }

  .footer__bar {
    position: relative;
    z-index: 1;
    max-width: 1320px;
    margin: 34px auto 0;
    padding: 20px var(--gutter) 40px;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px 20px;
  }
  .footer__copy {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 16px;
    font-size: 11.5px;
    color: var(--ink-3);
  }
  .footer__copy a {
    color: var(--ink-3);
    transition: color var(--d-fast) var(--e-out);
  }
  .footer__copy a:hover {
    color: var(--ink-2);
  }
  .footer__chips {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer__chip {
    font-size: 11px;
    color: var(--ink-2);
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    padding: 6px 12px;
    white-space: nowrap;
  }
  .footer__chip--on {
    color: var(--ember);
    border-color: var(--ember-soft);
    background: rgba(204, 106, 67, 0.06);
  }

  /* Tablet: brand spans the top, the two link cols sit below side-by-side. */
  @media (max-width: 860px) {
    .footer__wrap {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }
  /* Mobile: single column stack - brand, then each link col. */
  @media (max-width: 560px) {
    .footer__wrap {
      grid-template-columns: minmax(0, 1fr);
      gap: 32px;
    }
    .footer__brand {
      grid-column: auto;
    }
  }
</style>
