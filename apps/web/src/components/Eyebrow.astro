---
/**
 * Eyebrow (DESIGN.md §8) - a small dark-glass pill with an ember dot. One of the
 * ≤4 ember touches per viewport. Forwards `data-*` (e.g. `data-anim`).
 */
interface Props {
  text: string;
  class?: string;
  [key: `data-${string}`]: string | undefined;
}
const { text, class: className, ...rest } = Astro.props;
---

<p class:list={['eyebrow', className]} {...rest}>
  <span class="eyebrow__dot" aria-hidden="true"></span>
  <span>{text}</span>
</p>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 7px 14px 7px 12px;
    background: rgba(241, 239, 234, 0.03);
    border: 1px solid var(--line);
    border-radius: var(--r-pill);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.01em;
    color: var(--ink-2);
  }
  .eyebrow__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
    flex: none;
  }
</style>
