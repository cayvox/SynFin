---
/**
 * Eyebrow - a section marker drawn as an instrument label rather than a
 * dot-in-pill chip: a short ember rule followed by a mono, uppercase, tracked
 * label. The ember rule is the section's single ember touch. Forwards `data-*`
 * (e.g. `data-anim`).
 */
interface Props {
  text: string;
  class?: string;
  [key: `data-${string}`]: string | undefined;
}
const { text, class: className, ...rest } = Astro.props;
---

<p class:list={['eyebrow', className]} {...rest}>
  <span class="eyebrow__rule" aria-hidden="true"></span>
  <span class="eyebrow__label">{text}</span>
</p>

<style>
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .eyebrow__rule {
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--ember), var(--ember-soft));
    box-shadow: 0 0 10px -1px var(--ember-soft);
    flex: none;
  }
  .eyebrow__label {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11.5px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-3);
  }
</style>
