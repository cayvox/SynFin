---
/**
 * Button (DESIGN.md §5) — pill. `primary`: warm-white fill, dark text, inset top
 * highlight + soft shadow, hover → pure white. `ghost`: faint fill + hairline
 * border, light text. Renders <a> when `href` is set, else <button>. All states
 * crafted; focus-visible = ember ring.
 */
interface Props {
  variant?: 'primary' | 'ghost';
  href?: string;
  type?: 'button' | 'submit';
  disabled?: boolean;
  block?: boolean;
  class?: string;
  rel?: string;
  target?: string;
  'aria-label'?: string;
}
const {
  variant = 'primary',
  href,
  type = 'button',
  disabled = false,
  block = false,
  class: className,
  ...rest
} = Astro.props;
const cls = ['btn', `btn--${variant}`, block && 'btn--block', className];
const Tag = href ? 'a' : 'button';
---

<Tag class:list={cls} {...href ? { href } : { type, disabled }} {...rest}>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 11px 20px;
    border-radius: var(--r-pill);
    font-family: var(--font-ui);
    font-weight: 500;
    font-size: 14px;
    letter-spacing: -0.005em;
    line-height: 1;
    white-space: nowrap;
    border: 1px solid transparent;
    transition:
      background var(--d-fast) var(--e-out),
      border-color var(--d-fast) var(--e-out),
      color var(--d-fast) var(--e-out),
      transform var(--d-fast) var(--e-out),
      box-shadow var(--d-fast) var(--e-out);
  }
  .btn--block {
    width: 100%;
  }

  /* Primary — warm-white fill, dark text, inset highlight + soft shadow. */
  .btn--primary {
    background: var(--ink);
    color: var(--on-light);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 10px 24px -14px rgba(0, 0, 0, 0.9);
  }
  .btn--primary:hover {
    background: #fff;
    transform: translateY(-1px);
  }
  .btn--primary:active {
    transform: translateY(0);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 4px 12px -10px rgba(0, 0, 0, 0.9);
  }

  /* Ghost — faint fill + hairline border. */
  .btn--ghost {
    background: rgba(241, 239, 234, 0.03);
    color: var(--ink);
    border-color: var(--line-2);
  }
  .btn--ghost:hover {
    background: rgba(241, 239, 234, 0.07);
    border-color: var(--line-2);
  }
  .btn--ghost:active {
    transform: translateY(0.5px);
  }

  .btn:focus-visible {
    outline: 2px solid var(--ember);
    outline-offset: 3px;
  }

  .btn:disabled,
  .btn[aria-disabled='true'] {
    opacity: 0.45;
    cursor: not-allowed;
    transform: none;
    pointer-events: none;
  }
</style>
