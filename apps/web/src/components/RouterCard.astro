---
/**
 * RouterCard (DESIGN.md §5; CONTENT.md §4) - the best-execution card, dark-glass
 * re-skin, living in the Proof bento (NOT the hero). The canonical illustrative
 * demo: 250,000 CC → split 46/33/21 across CantonSwap/OneSwap/RFQ desk, +47.8 bps
 * edge, atomic per-leg-private settlement. Allocation bars fill with warm-white
 * (--ink), NOT ember; ember appears only on the +47.8 edge and the seal-check.
 * No fake "live" pulse. Numbers are illustrative - never measured/live.
 *
 * Animation hooks for proof.ts: each `.rc-bar__fill` carries its final width as
 * `--pct` (full by default → no-JS/reduced shows it full); the edge number's
 * final value is in the DOM with `data-count-to`. Tabular, width reserved.
 */
import SealMark from './SealMark.astro';

const venues = [
  { name: 'CantonSwap', pct: 46, receive: '18,372' },
  { name: 'OneSwap', pct: 33, receive: '13,181' },
  { name: 'RFQ desk', pct: 21, receive: '8,387' },
];
---

<article class="rc" aria-label="Best-execution router (illustrative demo)">
  <header class="rc__head">
    <span class="rc__title">Best execution</span>
    <span class="rc__pair mono">CC → USDCx</span>
  </header>

  <div class="rc__input">
    <span class="rc__label">You route</span>
    <div class="rc__amount mono">250,000 <span class="rc__ccy">CC</span></div>
    <span class="rc__slip mono">slippage 0.30%</span>
  </div>

  <div class="rc__split">
    <div class="rc__split-head">
      <span class="rc__label">Best route, split across 3 venues</span>
      <span class="rc__tag mono">RFQ + AMM</span>
    </div>
    <ul class="rc__venues">
      {
        venues.map((v) => (
          <li class="rc-venue">
            <span class="rc-venue__mark" aria-hidden="true" />
            <span class="rc-venue__name">{v.name}</span>
            <span class="rc-venue__pct mono">{v.pct}%</span>
            <span class="rc-bar">
              <span class="rc-bar__fill" style={`--pct:${v.pct}%`} />
            </span>
            <span class="rc-venue__recv mono">
              {v.receive} <span class="rc-venue__ccy">USDCx</span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="rc__edge">
    <div class="rc__edge-num">
      <span class="rc__edge-val" data-count-to="47.8">+47.8</span>
      <span class="rc__edge-unit">bps</span>
    </div>
    <div class="rc__edge-meta">
      <span class="rc__label">better than the best single venue</span>
      <span class="rc__edge-abs mono"
        >≈ +191 USDCx more, you receive 39,940</span
      >
    </div>
  </div>

  <div class="rc__settle">
    <SealMark size={20} check decorative class="rc__seal" />
    <span
      >Settles atomically. Every leg in one transaction, each venue sees only
      its own.</span
    >
  </div>

  <p class="rc__demo mono">Illustrative example. Not live or measured data.</p>
</article>

<style>
  .rc {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    height: 100%;
  }

  .rc__label {
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-3);
  }

  .rc__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rc__title {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
  }
  .rc__pair {
    font-size: 13px;
    color: var(--ink-2);
  }

  .rc__input {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 4px 12px;
    padding: 16px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
  }
  .rc__input .rc__label {
    grid-column: 1;
  }
  .rc__amount {
    grid-column: 1;
    font-size: 30px;
    font-weight: 500;
    line-height: 1.05;
    color: var(--ink);
  }
  .rc__ccy {
    font-size: 16px;
    color: var(--ink-2);
  }
  .rc__slip {
    grid-column: 2;
    grid-row: 2;
    align-self: end;
    font-size: 12px;
    color: var(--ink-2);
  }

  .rc__split-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .rc__tag {
    font-size: 11px;
    color: var(--ink-3);
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    padding: 2px 8px;
  }
  .rc__venues {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .rc-venue {
    display: grid;
    grid-template-columns: 10px 1fr auto;
    align-items: center;
    column-gap: 12px;
    row-gap: 5px;
    padding: 8px;
    border-radius: var(--r-xs);
    transition: background var(--d-fast) var(--e-out);
  }
  .rc-venue:hover {
    background: var(--bg-3);
  }
  .rc-venue__mark {
    width: 9px;
    height: 9px;
    border: 1px solid var(--ink-3);
    border-radius: 2px;
  }
  .rc-venue__name {
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--ink);
  }
  .rc-venue__pct {
    font-size: 13px;
    color: var(--ink-2);
    text-align: right;
    min-width: 3.2ch;
  }
  .rc-bar {
    grid-column: 2 / 4;
    height: 4px;
    border-radius: 2px;
    background: var(--line);
    overflow: hidden;
  }
  .rc-bar__fill {
    display: block;
    height: 100%;
    width: var(--pct);
    background: var(--ink);
    border-radius: 2px;
  }
  .rc-venue__recv {
    grid-column: 2 / 4;
    font-size: 12px;
    color: var(--ink-2);
    text-align: right;
  }
  .rc-venue__ccy {
    color: var(--ink-3);
  }

  .rc__edge {
    display: flex;
    align-items: center;
    gap: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }
  .rc__edge-num {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    color: var(--ember);
  }
  .rc__edge-val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 44px;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    min-width: 3.4ch;
    display: inline-block;
  }
  .rc__edge-unit {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 15px;
    color: var(--ember);
  }
  .rc__edge-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .rc__edge-abs {
    font-size: 12px;
    color: var(--ink-2);
  }

  .rc__settle {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 12px 14px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--ink-2);
  }

  .rc__demo {
    margin: -6px 0 0;
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--ink-3);
  }

  @media (max-width: 460px) {
    .rc {
      padding: 18px;
    }
    .rc__amount {
      font-size: 26px;
    }
    .rc__edge-val {
      font-size: 38px;
    }
  }
</style>
