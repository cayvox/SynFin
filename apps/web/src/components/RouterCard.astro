---
/**
 * RouterCard (DESIGN.md §5; CONTENT.md §4) - the best-execution card in the Proof
 * bento (NOT the hero). Reads the canonical large-order snapshot from
 * src/data/market.ts: sell 250,000 CC, depth-aware split across the five venues,
 * settled atomically. The single ember payoff is the edge the best quote
 * (OneSwap) holds over the next venue; the routed total and blended price are
 * derived. Allocation bars fill warm-white (--ink), not ember. Numbers are
 * illustrative, never measured.
 *
 * proof.ts hooks: each `.rc-bar__fill` carries `--pct` (full by default); the
 * edge number's value is in the DOM with `data-count-to`.
 */
import SealMark from './SealMark.astro';
import {
  BASE,
  QUOTE,
  LARGE_SELL_CC,
  legs,
  largeTotalOut,
  largeBlendedPrice,
  edgeVsNextBps,
  best,
  fmtAmount,
  fmtBps,
  fmtPrice,
} from '../data/market.ts';

const edge = fmtBps(edgeVsNextBps);
---

<article class="rc" aria-label="Best-execution router (illustrative demo)">
  <header class="rc__head">
    <span class="rc__title">Best execution</span>
    <span class="rc__pair mono">{BASE} → {QUOTE}</span>
  </header>

  <div class="rc__input">
    <span class="rc__label">You route</span>
    <div class="rc__amount mono">
      {fmtAmount(LARGE_SELL_CC)}
      <span class="rc__ccy">{BASE}</span>
    </div>
    <span class="rc__slip mono">blended {fmtPrice(largeBlendedPrice)}</span>
  </div>

  <div class="rc__split">
    <div class="rc__split-head">
      <span class="rc__label"
        >Best route, split across {legs.length} venues</span
      >
      <span class="rc__tag mono">RFQ + AMM</span>
    </div>
    <ul class="rc__venues">
      {
        legs.map((l) => (
          <li class="rc-venue">
            <span class="rc-venue__mark" aria-hidden="true" />
            <span class="rc-venue__name">{l.name}</span>
            <span class="rc-venue__pct mono">{Math.round(l.sharePct)}%</span>
            <span class="rc-bar">
              <span class="rc-bar__fill" style={`--pct:${l.sharePct}%`} />
            </span>
            <span class="rc-venue__recv mono">
              {fmtAmount(l.outUSDCx)} <span class="rc-venue__ccy">{QUOTE}</span>
            </span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="rc__edge">
    <div class="rc__edge-num">
      <span class="rc__edge-val" data-count-to={edge}>+{edge}</span>
      <span class="rc__edge-unit">bps</span>
    </div>
    <div class="rc__edge-meta">
      <span class="rc__label"
        >{best.name}, the best quote, over the next venue</span
      >
      <span class="rc__edge-abs mono"
        >you receive {fmtAmount(largeTotalOut)} {QUOTE}</span
      >
    </div>
  </div>

  <div class="rc__settle">
    <SealMark size={20} check decorative class="rc__seal" />
    <span
      >Settles atomically. Every leg in one transaction, each venue sees only
      its own.</span
    >
  </div>

  <p class="rc__demo mono">Illustrative example. Not live or measured data.</p>
</article>

<style>
  .rc {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    height: 100%;
  }

  .rc__label {
    font-family: var(--font-ui);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-3);
  }

  .rc__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .rc__title {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
  }
  .rc__pair {
    font-size: 13px;
    color: var(--ink-2);
  }

  .rc__input {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 4px 12px;
    padding: 16px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
  }
  .rc__input .rc__label {
    grid-column: 1;
  }
  .rc__amount {
    grid-column: 1;
    font-size: 30px;
    font-weight: 500;
    line-height: 1.05;
    color: var(--ink);
  }
  .rc__ccy {
    font-size: 16px;
    color: var(--ink-2);
  }
  .rc__slip {
    grid-column: 2;
    grid-row: 2;
    align-self: end;
    font-size: 12px;
    color: var(--ink-2);
  }

  .rc__split-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .rc__tag {
    font-size: 11px;
    color: var(--ink-3);
    border: 1px solid var(--line-2);
    border-radius: var(--r-pill);
    padding: 2px 8px;
  }
  .rc__venues {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .rc-venue {
    display: grid;
    grid-template-columns: 10px 1fr auto;
    align-items: center;
    column-gap: 12px;
    row-gap: 5px;
    padding: 8px;
    border-radius: var(--r-xs);
    transition: background var(--d-fast) var(--e-out);
  }
  .rc-venue:hover {
    background: var(--bg-3);
  }
  .rc-venue__mark {
    width: 9px;
    height: 9px;
    border: 1px solid var(--ink-3);
    border-radius: 2px;
  }
  .rc-venue__name {
    font-family: var(--font-ui);
    font-size: 14px;
    color: var(--ink);
  }
  .rc-venue__pct {
    font-size: 13px;
    color: var(--ink-2);
    text-align: right;
    min-width: 3.2ch;
  }
  .rc-bar {
    grid-column: 2 / 4;
    height: 4px;
    border-radius: 2px;
    background: var(--line);
    overflow: hidden;
  }
  .rc-bar__fill {
    display: block;
    height: 100%;
    width: var(--pct);
    background: var(--ink);
    border-radius: 2px;
  }
  .rc-venue__recv {
    grid-column: 2 / 4;
    font-size: 12px;
    color: var(--ink-2);
    text-align: right;
  }
  .rc-venue__ccy {
    color: var(--ink-3);
  }

  .rc__edge {
    display: flex;
    align-items: center;
    gap: 18px;
    padding-top: 18px;
    border-top: 1px solid var(--line);
  }
  .rc__edge-num {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    color: var(--ember);
  }
  .rc__edge-val {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 44px;
    line-height: 0.9;
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    min-width: 3.4ch;
    display: inline-block;
  }
  .rc__edge-unit {
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 15px;
    color: var(--ember);
  }
  .rc__edge-meta {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .rc__edge-abs {
    font-size: 12px;
    color: var(--ink-2);
  }

  .rc__settle {
    display: flex;
    align-items: center;
    gap: 11px;
    padding: 12px 14px;
    background: var(--bg-2);
    border: 1px solid var(--line);
    border-radius: var(--r-sm);
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--ink-2);
  }

  .rc__demo {
    margin: -6px 0 0;
    font-size: 11px;
    letter-spacing: 0.02em;
    color: var(--ink-3);
  }

  @media (max-width: 460px) {
    .rc {
      padding: 18px;
    }
    .rc__amount {
      font-size: 26px;
    }
    .rc__edge-val {
      font-size: 38px;
    }
  }
</style>
