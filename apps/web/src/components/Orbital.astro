---
/**
 * Orbital (DESIGN.md §3) - the router radar, driven as ONE coherent state
 * machine across the four How-it-works steps and reading the canonical market
 * (src/data/market.ts), so its venues, winner, edge and gaps always match the
 * hero and Problem sections.
 *
 * The active step is `data-step` on `.orb` (1..4), set by orbital.ts (auto
 * stepper + hover on the step list). CSS keys every layer off it:
 *   1 Quote   - all five venues + live prices, a rotating sweep.
 *   2 Compare - winner (OneSwap) lit ember; others dimmed and labeled with their
 *               gap-behind-best in bps; meter shows the edge over the next best.
 *   3 Split   - allocation arms to the top venues, labeled in %, summing to 100.
 *   4 Settle  - the arms converge into one ember node: atomic settlement.
 * SSR default is step 2 (Compare), so no-JS and reduced-motion render an
 * informative, static state with every label legible.
 *
 * 560x560 viewBox; overlays positioned in PERCENT so the whole thing scales
 * uniformly. Venue label zones are reserved left / right / bottom so labels,
 * prices and step annotations never collide.
 */
import SealMark from './SealMark.astro';
import {
  ranked,
  edgeVsNextBps,
  gapBehindBestBps,
  isBest,
  fmtBps,
  fmtPrice,
} from '../data/market.ts';

const C = 280;
const R = 170;
// Five reserved slots (angle from top, clockwise) with an outward label side.
// Ranked venues fill them best-first: winner upper-left, worst at the bottom.
const slots = [
  { ang: -68, side: 'left' as const },
  { ang: -112, side: 'left' as const },
  { ang: 68, side: 'right' as const },
  { ang: 112, side: 'right' as const },
  { ang: 180, side: 'bottom' as const },
];

const nodes = ranked.map((v, i) => {
  const s = slots[i];
  if (!s) throw new Error('orbital: missing slot');
  const rad = (s.ang * Math.PI) / 180;
  const vx = C + R * Math.sin(rad);
  const vy = C - R * Math.cos(rad);
  return {
    name: v.name,
    price: v.price,
    gap: gapBehindBestBps(v),
    best: isBest(v),
    side: s.side,
    vx: +vx.toFixed(2),
    vy: +vy.toFixed(2),
    xPct: +((vx / 560) * 100).toFixed(3),
    yPct: +((vy / 560) * 100).toFixed(3),
  };
});

// Illustrative depth-aware split across the top three venues (sums to 100). At
// this small size the best venue fills most; splitting matters at larger size.
const SPLIT_PCT = [82, 13, 5];
const allocByName = new Map(
  nodes.slice(0, 3).map((n, i) => [n.name, SPLIT_PCT[i] ?? 0]),
);

const ticks = Array.from({ length: 12 }, (_, i) => i * 30);
const edge = fmtBps(edgeVsNextBps);
---

<div class="orb" data-step="2" data-orb>
  <div class="orb__glow" aria-hidden="true"></div>

  <svg class="orb__rings" viewBox="0 0 560 560" fill="none" aria-hidden="true">
    <defs>
      <filter id="orbGlow" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="1.0" result="b"></feGaussianBlur>
        <feMerge>
          <feMergeNode in="b"></feMergeNode>
          <feMergeNode in="SourceGraphic"></feMergeNode>
        </feMerge>
      </filter>
    </defs>

    <!-- concentric instrument rings -->
    <circle cx="280" cy="280" r="250" stroke="rgba(241,239,234,0.07)"></circle>
    <circle cx="280" cy="280" r="170" stroke="rgba(241,239,234,0.10)"></circle>
    <circle cx="280" cy="280" r="108" stroke="rgba(241,239,234,0.06)"></circle>
    <g stroke="rgba(241,239,234,0.16)">
      {
        ticks.map((deg) => (
          <line
            x1="280"
            y1="30"
            x2="280"
            y2="38"
            transform={`rotate(${deg} 280 280)`}
          />
        ))
      }
    </g>

    <!-- rotating sweep (step 1 only) -->
    <line class="orb-sweep" x1="280" y1="280" x2="280" y2="40"></line>

    <!-- spokes: one per venue, center -> node. Styled per step (scan / route /
         split / settle). The winner spoke is data-rank=0. -->
    <g class="orb-spokes" filter="url(#orbGlow)">
      {
        nodes.map((n, i) => (
          <path
            class:list={[
              'spoke',
              n.best && 'spoke--best',
              i < 3 && 'spoke--top',
            ]}
            data-rank={i}
            d={`M280 280 L${n.vx} ${n.vy}`}
          />
        ))
      }
    </g>
  </svg>

  <!-- top meter pill: one line per step, toggled by CSS -->
  <div class="orb__meter mono">
    <span class="orb__meter-dot" aria-hidden="true"></span>
    <span class="orb__meter-line" data-when="1"
      >scanning {nodes.length} venues</span
    >
    <span class="orb__meter-line" data-when="2">best route · +{edge} bps</span>
    <span class="orb__meter-line" data-when="3">optimal split · 3 venues</span>
    <span class="orb__meter-line" data-when="4"
      >settled · one Daml tx · per-leg private</span
    >
  </div>

  <div class="orb__core">
    <SealMark size={104} decorative class="orb__seal" title="Synfin router" />
    <span class="orb__core-ring" aria-hidden="true"></span>
  </div>

  {
    nodes.map((n, i) => (
      <div
        class:list={[
          'vn',
          `vn--${n.side}`,
          n.best && 'vn--best',
          i < 3 && 'vn--top',
        ]}
        style={`left:${n.xPct}%;top:${n.yPct}%`}
        data-rank={i}
      >
        <span class="vn__dot">
          <span class="vn__inner" />
        </span>
        <span class="vn__label">
          <span class="vn__name">{n.name}</span>
          <span class="vn__detail mono">
            <span class="vn__price" data-d="price">
              CC/USDCx {fmtPrice(n.price)}
            </span>
            <span class="vn__gap" data-d="gap">
              {n.best ? 'best' : `+${fmtBps(n.gap, 0)} bps behind`}
            </span>
            <span class="vn__alloc" data-d="alloc">
              {allocByName.has(n.name) ? `${allocByName.get(n.name)}%` : ''}
            </span>
          </span>
        </span>
      </div>
    ))
  }
</div>

<style>
  .orb {
    position: relative;
    width: min(560px, 100%);
    aspect-ratio: 1 / 1;
    margin-inline: auto;
  }
  .orb__glow {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 53.6%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--ember-glow),
      rgba(255, 106, 61, 0.05) 40%,
      transparent 68%
    );
    pointer-events: none;
  }
  .orb__rings {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .orb__rings circle,
  .orb__rings line {
    stroke-width: 1;
  }

  /* Sweep: a single rotating spoke, step 1 only, motion only. */
  .orb-sweep {
    stroke: var(--ember-soft);
    stroke-width: 1.5;
    stroke-linecap: round;
    transform-origin: 280px 280px;
    opacity: 0;
  }
  .orb[data-step='1'] .orb-sweep {
    opacity: 1;
    animation: orb-sweep 2.6s linear infinite;
  }
  @keyframes orb-sweep {
    to {
      transform: rotate(360deg);
    }
  }

  /* Spokes: faint by default (scan). The transition makes step changes smooth. */
  .spoke {
    stroke: rgba(241, 239, 234, 0.12);
    stroke-width: 1;
    stroke-linecap: round;
    transition:
      stroke 0.45s ease,
      stroke-width 0.45s ease,
      opacity 0.45s ease;
  }
  /* Step 2: only the winner spoke lights ember. */
  .orb[data-step='2'] .spoke--best {
    stroke: var(--ember);
    stroke-width: 1.8;
  }
  /* Step 3 + 4: the top-three split arms light ember. */
  .orb[data-step='3'] .spoke--top,
  .orb[data-step='4'] .spoke--top {
    stroke: var(--ember);
    stroke-width: 1.8;
  }
  .orb[data-step='3'] .spoke:not(.spoke--top),
  .orb[data-step='4'] .spoke:not(.spoke--top) {
    opacity: 0.25;
  }
  /* Step 4: a pulse flows down the arms into the centre. */
  .orb[data-step='4'] .spoke--top {
    stroke-dasharray: 26 320;
    animation: orb-converge 1.5s ease-in-out infinite;
  }
  @keyframes orb-converge {
    from {
      stroke-dashoffset: 0;
    }
    to {
      stroke-dashoffset: 346;
    }
  }

  /* Center router core. In step 4 it lights as the settlement node. */
  .orb__core {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18.6%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
  }
  .orb__core :global(.orb__seal) {
    width: 100%;
    height: 100%;
  }
  .orb__core-ring {
    position: absolute;
    width: 16%;
    aspect-ratio: 1;
    border-radius: 50%;
    border: 2px solid var(--ember-soft);
    opacity: 0.5;
    transition:
      opacity 0.4s ease,
      box-shadow 0.4s ease;
  }
  .orb[data-step='4'] .orb__core-ring {
    opacity: 1;
    box-shadow:
      0 0 0 4px var(--ember-glow),
      0 0 22px 2px var(--ember-soft);
    animation: orb-core-pulse 1.8s var(--e-inout) infinite;
  }
  @keyframes orb-core-pulse {
    0%,
    100% {
      box-shadow:
        0 0 0 3px var(--ember-glow),
        0 0 14px 0 var(--ember-soft);
    }
    50% {
      box-shadow:
        0 0 0 6px var(--ember-glow),
        0 0 26px 3px var(--ember-soft);
    }
  }

  /* Meter pill */
  .orb__meter {
    position: absolute;
    left: 50%;
    top: 1%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    font-size: 11.5px;
    letter-spacing: 0.02em;
    color: var(--ember-hi);
    background: color-mix(in srgb, var(--bg) 84%, var(--ember) 16%);
    border: 1px solid var(--ember-soft);
    border-radius: var(--r-pill);
    box-shadow: 0 0 22px -2px var(--ember-glow);
    white-space: nowrap;
  }
  .orb__meter-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
    flex: none;
  }
  .orb__meter-line {
    display: none;
    font-variant-numeric: tabular-nums;
  }
  .orb[data-step='1'] .orb__meter-line[data-when='1'],
  .orb[data-step='2'] .orb__meter-line[data-when='2'],
  .orb[data-step='3'] .orb__meter-line[data-when='3'],
  .orb[data-step='4'] .orb__meter-line[data-when='4'] {
    display: inline;
  }

  /* Venue nodes. The dot is the anchor on the orbit; the label floats outward on
     its reserved side so labels never collide with each other or the spokes. */
  .vn {
    position: absolute;
    transform: translate(-50%, -50%);
    z-index: 3;
    transition: opacity 0.4s ease;
  }
  .vn__dot {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: radial-gradient(
      circle at 50% 34%,
      rgba(241, 239, 234, 0.12),
      rgba(20, 21, 25, 0.75)
    );
    border: 1px solid var(--line-2);
  }
  .vn__inner {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1.25px solid var(--ink-2);
    transition:
      border-color 0.4s ease,
      box-shadow 0.4s ease;
  }
  .vn__label {
    position: absolute;
    top: 50%;
    display: flex;
    flex-direction: column;
    transform: translateY(-50%);
    white-space: nowrap;
  }
  /* Reserved label zones: left venues label to the left, right to the right,
     bottom below. Fixed widths keep zones from overlapping the centre. */
  .vn--left .vn__label {
    right: calc(100% + 12px);
    align-items: flex-end;
    text-align: right;
  }
  .vn--right .vn__label {
    left: calc(100% + 12px);
    align-items: flex-start;
    text-align: left;
  }
  .vn--bottom .vn__label {
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    align-items: center;
    text-align: center;
  }
  .vn__name {
    font-size: 12.5px;
    font-weight: 500;
    color: var(--ink);
    transition: color 0.4s ease;
  }
  .vn__detail {
    margin-top: 2px;
    font-size: 11px;
    color: var(--ink-3);
    min-height: 1em;
  }
  .vn__detail [data-d] {
    display: none;
  }
  /* Which detail shows per step. */
  .orb[data-step='1'] .vn__price,
  .orb[data-step='2'] .vn__gap,
  .orb[data-step='3'] .vn--top .vn__alloc {
    display: inline;
  }
  /* Winner emphasis in Compare/Split/Settle. */
  .orb:not([data-step='1']) .vn--best .vn__inner {
    border-color: var(--ember);
    box-shadow: 0 0 8px 0 var(--ember-soft);
  }
  .orb[data-step='2'] .vn--best .vn__name,
  .orb[data-step='2'] .vn--best .vn__gap,
  .orb[data-step='3'] .vn--top .vn__alloc {
    color: var(--ember-tx);
  }
  /* Dim the also-rans so the winner / split reads first. */
  .orb[data-step='2'] .vn:not(.vn--best),
  .orb[data-step='3'] .vn:not(.vn--top),
  .orb[data-step='4'] .vn:not(.vn--best) {
    opacity: 0.5;
  }

  /* Reduced motion: no sweep, no converge flow, no core pulse (handled by the
     global reduce rules too); the static Compare state stays fully legible. */
  @media (prefers-reduced-motion: reduce) {
    .orb-sweep,
    .orb[data-step='4'] .spoke--top,
    .orb[data-step='4'] .orb__core-ring {
      animation: none;
    }
  }
</style>
