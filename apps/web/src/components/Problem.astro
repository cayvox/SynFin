---
/**
 * §2 "The problem" (CONTENT.md §2; DESIGN.md §12) - a calm editorial breather
 * between the hero and the orbital. Mostly type: tonal heading, a lead + two
 * supporting paragraphs in a ~620px column, and a mono pull-stat whose "0"
 * carries the single ember accent. One quiet §7 wash.
 */
import Eyebrow from './Eyebrow.astro';
---

<section id="problem" class="problem" aria-labelledby="problem-title">
  <div class="container">
    <header class="problem__head" data-reveal>
      <Eyebrow text="01 · The problem" />
      <h2 class="problem__title" id="problem-title">
        Every venue
        <span class="problem__muted">prices it differently.</span>
      </h2>
    </header>

    <div class="problem__body" data-reveal>
      <p>
        Canton's liquidity is spreading across AMMs, order books, and RFQ desks.
        Each one quotes the same pair at a different price, and there is no
        neutral layer comparing them. So every trade risks the wrong venue, and
        every team rebuilds the same routing logic. Synfin is that layer.
      </p>
    </div>

    <p class="problem__stat mono" data-reveal>
      <span class="problem__pull">
        One standard for tokens. No standard for getting the best price.
      </span>
      <span class="problem__pull-sub">That is the layer Synfin builds.</span>
    </p>
  </div>
</section>

<style>
  .problem {
    position: relative;
    padding-top: var(--sp-default);
    padding-bottom: var(--sp-default);
    overflow: hidden;
  }
  .problem > .container {
    position: relative;
    z-index: 1;
  }

  .problem__head {
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 720px;
  }
  .problem__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(30px, 4.4vw, 50px);
    line-height: 1.06;
    letter-spacing: -0.025em;
    display: flex;
    flex-direction: column;
  }
  .problem__muted {
    color: var(--ink-display-muted);
  }

  .problem__body {
    margin-top: 34px;
    max-width: 620px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    font-size: 16.5px;
    line-height: 1.65;
    color: var(--ink-2);
  }
  .problem__body em {
    font-style: normal;
    color: var(--ink);
  }

  .problem__stat {
    margin-top: 40px;
    font-size: 14px;
    letter-spacing: 0.02em;
    color: var(--ink-3);
  }
  .problem__pull {
    display: block;
    color: var(--ink);
  }
  .problem__pull-sub {
    display: block;
    margin-top: 6px;
    color: var(--ink-3);
  }
</style>
