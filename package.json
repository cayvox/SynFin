{
  "name": "@synfin/monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Synfin: open, neutral best-execution and liquidity-routing standard + Apache-2.0 reference implementation for the Canton Network.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "gen": "pnpm -r gen",
    "gen:check": "pnpm -r gen:check",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:verify": "node scripts/release-verify.mjs",
    "release:verify:verdaccio": "bash scripts/release-verify-verdaccio.sh"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@eslint/js": "9.17.0",
    "astro-eslint-parser": "1.4.0",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-astro": "1.7.0",
    "prettier": "3.4.2",
    "prettier-plugin-astro": "0.14.1",
    "publint": "^0.3.21",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.1"
  }
}
