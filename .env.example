# Synfin — environment placeholders. Copy to `.env` and fill locally.
# NEVER commit real secrets. Only this `.env.example` is tracked (see .gitignore,
# ENGINEERING.md §6). Nothing here is read at build time.

# --- @synfin/cli, Demo 1 (quote aggregation) ---------------------------------
# OneSwap quoting requires an API key (read-only price preview; no funds move).
# Without it, the CLI skips OneSwap live and falls back to recorded fixtures.
# Obtain a key at https://oneswap.cc/developer/keys (devnet: https://devnet.oneswap.cc/developer/keys).
ONESWAP_API_KEY=

# Base URL of the OneSwap quote backend the SDK/API serves (required for live
# OneSwap quotes alongside the key). Leave blank to use fixtures.
ONESWAP_BASE_URL=

# CantonSwap needs no API key — its public quote endpoint is read-only.
