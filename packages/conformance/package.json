{
  "name": "@synfin/conformance",
  "version": "0.1.0",
  "description": "Reusable Synfin conformance harness — runners that any VenueAdapter or Router can import to claim SQSS conformance (TESTING.md §5).",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@synfin/spec": "workspace:*",
    "fast-check": "3.23.1"
  },
  "devDependencies": {
    "@synfin/adapters": "workspace:*",
    "@synfin/router-ref": "workspace:*",
    "@vitest/coverage-v8": "2.1.8",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
