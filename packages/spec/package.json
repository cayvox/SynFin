{
  "name": "@synfin/spec",
  "version": "0.2.0",
  "description": "Normative TypeScript types, JSON Schemas, runtime validators and the three Synfin ports (single source of truth for SQSS).",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "gen": "node scripts/gen.mjs",
    "gen:check": "node scripts/gen.mjs --check",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "ajv": "8.17.1",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.8",
    "fast-check": "3.23.1",
    "json-schema-to-typescript": "15.0.3",
    "prettier": "3.4.2",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
