{
  "name": "@synfin/cli",
  "version": "0.1.0",
  "description": "Synfin reference CLI — Demo 1: cross-venue quote aggregation against real Canton venues (CantonSwap, OneSwap). Read-only, no funds.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "synfin": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@synfin/adapters": "workspace:*",
    "@synfin/router-ref": "workspace:*",
    "@synfin/spec": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "@vitest/coverage-v8": "2.1.8",
    "typescript": "5.7.2",
    "vitest": "2.1.8"
  }
}
