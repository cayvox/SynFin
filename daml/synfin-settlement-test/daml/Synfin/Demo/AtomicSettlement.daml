--
-- | DEMO 2 — a narrated, end-to-end demonstration of Synfin's atomic,
-- per-leg-private split SETTLEMENT (SPEC §6, §7; ADR-0008; RFC-0003), run
-- against our OWN CIP-0056 test venue (Amulet) on a local in-memory ledger.
--
-- This is a DEMONSTRATION, not new logic: it reuses the
-- `daml/synfin-settlement` library UNCHANGED (the same `SwapSettlement` /
-- `LegAuth` model proven by the Task-003.6 test matrix, incl.
-- `testPerLegVisibility`) and the existing test setup helpers from
-- `Synfin.Tests.Settlement`. It narrates, via `debug`, exactly what the proven
-- guarantees deliver:
--
--   * a 2-venue (4-leg) split settles ATOMICALLY in ONE transaction
--     (all-or-nothing — ARCHITECTURE.md §1 invariant #3);
--   * the taker's economic bounds (conservation / minReceive / slippage /
--     deadline) are enforced ON-LEDGER (SPEC §6 step 3);
--   * allocations are single-use (none remain after settlement); and
--   * PER-LEG PRIVACY (SPEC §7): venue A cannot see venue B's leg, while the
--     taker + executor see the aggregate route.
--
-- HONEST FRAMING (ADR-0009, decision (a)): this demonstrates the architecture
-- against our own CIP-0056 Mode-A test venue (Amulet) — it is "ready for Mode-A
-- venues as the network matures", NOT a claim of atomic settlement against live
-- third-party venues (ADR-0009 confirmed none expose CIP-0056 allocation
-- co-settlement today; those are Mode B / quote-only).
module Synfin.Demo.AtomicSettlement where

import Daml.Script
import DA.Assert ((===))
import DA.TextMap qualified as TextMap

import Splice.Api.Token.AllocationV1 (Allocation)

import Synfin.Tests.Settlement (Fixture (..), gatherLegAllocations, setupStandard, settle)

import Splice.Testing.TokenStandard.WalletClient qualified as WalletClient

-- | Narrate a demonstration step to the script log (shown by `daml test`).
narrate : Text -> Script ()
narrate = debug

-- | The Demo 2 scenario. Runs as part of `daml test` (so it is also a passing,
-- regression-guarded script), and is what the CLI `settle-demo` command drives.
demoAtomicSettlement : Script ()
demoAtomicSettlement = script do
  narrate "=============================================================="
  narrate "SYNFIN DEMO 2 - atomic, per-leg-private split SETTLEMENT"
  narrate "Venue: our OWN CIP-0056 test venue (Amulet), local in-memory ledger."
  narrate "Reuses daml/synfin-settlement UNCHANGED (proven in Task 003.6)."
  narrate "Architecture ready for Mode-A venues; NOT a claim vs live venues today."
  narrate "--------------------------------------------------------------"

  f@Fixture {..} <- setupStandard
  narrate "Route: taker 'alice' gives 100 Amulet (60 -> venue 'bob', 40 -> venue 'charlie'),"
  narrate "       and receives 120 back (70 from bob, 50 from charlie): a 2-venue, 4-leg split."

  -- PER-LEG PRIVACY (SPEC §7; mirrors testPerLegVisibility) -----------------
  bobAllocs <- queryInterface @Allocation bob
  charlieAllocs <- queryInterface @Allocation charlie
  execAllocs <- queryInterface @Allocation executor
  let allocSenders xs = [v.allocation.transferLeg.sender | (_, Some v) <- xs]
  -- Each venue is a stakeholder ONLY of the allocation for its own leg.
  allocSenders bobAllocs === [bob]
  allocSenders charlieAllocs === [charlie]
  assertMsg "bob must NOT see charlie's leg"
    (not (any (\(_, mv) -> optional False (\v -> v.allocation.transferLeg.sender == charlie) mv) bobAllocs))
  assertMsg "charlie must NOT see bob's leg"
    (not (any (\(_, mv) -> optional False (\v -> v.allocation.transferLeg.sender == bob) mv) charlieAllocs))
  length execAllocs === 4
  narrate "PER-LEG PRIVACY: bob sees ONLY its own leg; charlie sees ONLY its own leg;"
  narrate "                 the executor (coordinator) sees all 4 legs; venues never"
  narrate "                 see each other's leg or the aggregate route (SPEC 7)."

  -- ATOMIC SETTLEMENT (SPEC §6; one transaction, all-or-nothing) -------------
  (m, disclosures) <- gatherLegAllocations registry executor ref legAuths
  TextMap.size m === 4
  results <- settle f m disclosures
  TextMap.size results === 4
  narrate "ATOMIC SETTLEMENT: all 4 legs executed in ONE transaction (all-or-nothing)."

  -- Balances prove the swap actually moved on-ledger.
  WalletClient.checkHoldingWithAmountExists alice amuletId 70.0
  WalletClient.checkHoldingWithAmountExists alice amuletId 50.0
  WalletClient.checkHoldingWithAmountExists bob amuletId 60.0
  WalletClient.checkHoldingWithAmountExists charlie amuletId 40.0
  narrate "ON-LEDGER BOUNDS enforced before settling: conservation (give = 100),"
  narrate "                 minReceive >= 100, slippage <= 10%, and the deadline."

  -- Single-use allocations: nothing left to replay.
  remaining <- queryInterface @Allocation executor
  length remaining === 0
  narrate "SINGLE-USE allocations: none remain after settlement (no double-spend)."
  narrate "--------------------------------------------------------------"
  narrate "DEMO 2 RESULT: PASS - atomic, per-leg-private split settlement verified"
  narrate "               against our CIP-0056 test venue (Amulet)."
  narrate "=============================================================="
