--
-- | Synfin on-ledger atomic multi-leg settlement (SPEC Â§6, Â§7; ADR-0008; RFC-0003).
--
-- Composes an N-leg route into a SINGLE atomic Daml transaction on the real
-- CIP-0056 token-standard allocation interfaces â€” all-or-nothing
-- (ARCHITECTURE.md Â§1 invariant #3) â€” while keeping each venue blind to the
-- other legs (SPEC Â§7). The taker's economic bounds (`minReceive`,
-- `maxSlippageBps`, `deadline`) are enforced on-ledger, so a lying quote causes
-- a safe abort, not a loss (SPEC Â§6 step 3).
--
-- PRIVACY MODEL (RFC-0003). Per-leg authorization + executor-only coordinator:
--
--   * Each leg's two parties (sender + receiver) co-sign a `LegAuth` that
--     references ONLY that leg â€” never the aggregate route.
--   * The `SwapSettlement` coordinator is signed by the `executor` and the
--     `taker` ONLY (not the venues), and settles by exercising each `LegAuth`
--     inside one transaction. Each `LegAuth_Execute` supplies its leg's
--     sender+receiver authority, which `Allocation_ExecuteTransfer` requires
--     (its controllers are [executor, sender, receiver]).
--
-- Result: only the taker and executor ever see the aggregate; a venue is a
-- stakeholder only of its own leg(s) and never observes another venue's leg.
-- This supersedes the co-signed OTCTrade-style pattern, which RFC-0003 found
-- non-conformant for multi-venue routing.
module Synfin.Settlement where

import DA.TextMap (TextMap)
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1 (ChoiceExecutionMetadata (..), ExtraArgs, emptyMetadata)
import Splice.Api.Token.HoldingV1 (InstrumentId)
import Splice.Api.Token.AllocationV1
import Splice.Api.Token.AllocationRequestV1

-- | A single settlement leg: `sender` delivers `amount` of `instrument` to
-- `receiver`. A Synfin route is give-legs (taker â†’ venue, in the give asset)
-- and receive-legs (venue â†’ taker, in the want asset).
data Leg = Leg
  with
    sender : Party
    receiver : Party
    amount : Decimal
    instrument : InstrumentId
  deriving (Eq, Show)

-- | The values of a `TextMap` (helper; avoids relying on optional std APIs).
vals : TextMap a -> [a]
vals m = map snd (TextMap.toList m)

toTransferLeg : Leg -> TransferLeg
toTransferLeg leg = TransferLeg with
  sender = leg.sender
  receiver = leg.receiver
  amount = leg.amount
  instrumentId = leg.instrument
  meta = emptyMetadata

-- | Total amount delivered to `taker` in `instrument` across the legs.
deliveredTo : Party -> InstrumentId -> TextMap Leg -> Decimal
deliveredTo taker instrument legs =
  sum [ l.amount | l <- vals legs, l.receiver == taker, l.instrument == instrument ]

-- | Total amount the `taker` spends in `instrument` across the legs.
spentBy : Party -> InstrumentId -> TextMap Leg -> Decimal
spentBy taker instrument legs =
  sum [ l.amount | l <- vals legs, l.sender == taker, l.instrument == instrument ]

-- | The slippage floor: the least the taker may receive given an agreed
-- reference and `maxSlippageBps` (SPEC Â§4.1, Â§4.4). 1 bps = 0.01%.
slippageFloor : Decimal -> Int -> Decimal
slippageFloor referenceReceive maxSlippageBps =
  referenceReceive * intToDecimal (10000 - maxSlippageBps) / 10000.0

-- | A PER-LEG authorization co-signed by the leg's two parties (SPEC Â§7;
-- RFC-0003). It carries exactly the sender's and receiver's authority forward to
-- the `executor` so that `Allocation_ExecuteTransfer` / `Allocation_Cancel`
-- (controllers [executor, sender, receiver]) can run, WITHOUT the parties
-- co-signing the settling transaction. It references ONLY this leg's parties +
-- the settlement reference, so its signatories never learn any other leg or the
-- aggregate route. A venue co-signs only the `LegAuth`s for legs it is party to.
template LegAuth
  with
    settlementRef : Reference
      -- ^ Ties this authorization to one settlement (SPEC Â§6; CIP-0056 ref).
    sender : Party
    receiver : Party
    executor : Party
  where
    signatory sender, receiver
    observer executor

    -- | Supply this leg's sender+receiver authority to execute its allocation.
    nonconsuming choice LegAuth_Execute : Allocation_ExecuteTransferResult
      with
        allocCid : ContractId Allocation
        extraArgs : ExtraArgs
      controller executor
      do
        guardAllocationMatches this allocCid
        exercise allocCid (Allocation_ExecuteTransfer with extraArgs)

    -- | Supply this leg's authority to cancel/release its allocation.
    nonconsuming choice LegAuth_Cancel : Allocation_CancelResult
      with
        allocCid : ContractId Allocation
        extraArgs : ExtraArgs
      controller executor
      do
        guardAllocationMatches this allocCid
        exercise allocCid (Allocation_Cancel with extraArgs)

-- | An allocation may only be acted on through the `LegAuth` of its own leg:
-- its parties and settlement reference MUST match (defence in depth alongside
-- the coordinator's full-spec check).
guardAllocationMatches : LegAuth -> ContractId Allocation -> Update ()
guardAllocationMatches auth allocCid = do
  v <- view <$> fetch @Allocation allocCid
  assertMsg
    "allocation parties match this LegAuth"
    (v.allocation.transferLeg.sender == auth.sender && v.allocation.transferLeg.receiver == auth.receiver)
  assertMsg
    "allocation belongs to this settlement"
    (v.allocation.settlement.settlementRef == auth.settlementRef)

-- | The coordinating agreement that binds a Synfin route into one atomic
-- settlement (SPEC Â§6). Signed by the `executor` and the `taker` ONLY â€” venues
-- are NOT signatories or observers and never see this contract or the aggregate
-- `legs` (SPEC Â§7; RFC-0003). Venues participate solely through their own
-- per-leg `Allocation` and `LegAuth`.
template SwapSettlement
  with
    intentId : Text
      -- ^ Replay/idempotency key (SPEC Â§4.1, Â§6, Â§8). Carried in the CIP-0056
      -- settlement reference; the consuming `SwapSettlement_Settle` choice makes
      -- a retry a no-op (the contract is gone after the first settle).
    executor : Party
      -- ^ The settlement coordinator; controls execution and is the CIP-0056
      -- settlement `executor`.
    taker : Party
    giveInstrument : InstrumentId
    wantInstrument : InstrumentId
    giveAmount : Decimal
      -- ^ Total the taker gives; ÎŁ give-legs MUST equal this (conservation).
    minReceive : Decimal
      -- ^ Authoritative floor in the want instrument; settlement delivering less
      -- MUST abort (SPEC Â§4.1, Â§6). MUST be > 0 (checked at create).
    maxSlippageBps : Int
    referenceReceive : Decimal
      -- ^ The agreed reference the slippage bound is measured against (SPEC Â§4.1).
    legs : TextMap Leg
    createdAt : Time
    prepareUntil : Time
      -- ^ Allocations MUST be in place before this (CIP-0056 `allocateBefore`).
    deadline : Time
      -- ^ Settlement MUST NOT occur after this (SPEC Â§6; `settleBefore`).
  where
    signatory executor, taker
    ensure
      minReceive > 0.0
        && giveAmount > 0.0
        && maxSlippageBps >= 0
        && prepareUntil <= deadline

    -- | Standard `AllocationRequest` view (CIP-0056). Only `executor`/`taker`
    -- observe this contract, so the aggregate is never disclosed to a venue
    -- (SPEC Â§7); a venue receives its single leg off-ledger and allocates it.
    interface instance AllocationRequest for SwapSettlement where
      view = AllocationRequestView with
        settlement = settlementInfoOf this
        transferLegs = TextMap.fromList
          [ (k, toTransferLeg l) | (k, l) <- TextMap.toList this.legs ]
        meta = emptyMetadata
      allocationRequest_RejectImpl _self arg = do
        assertMsg
          "rejecting actor must be a sender on some leg"
          (any (\l -> arg.actor == l.sender) (vals this.legs))
        pure ChoiceExecutionMetadata with meta = emptyMetadata
      allocationRequest_WithdrawImpl _self _extraArgs =
        pure ChoiceExecutionMetadata with meta = emptyMetadata

    -- | Atomically settle every leg in ONE transaction (SPEC Â§6 steps 2â€“4).
    -- Enforces, on-ledger, all of the taker's economic bounds before executing,
    -- then exercises each leg's `LegAuth` (which supplies that leg's
    -- sender+receiver authority). Any failure (timing, bound, missing/mismatched
    -- allocation or auth) aborts the whole transaction so no leg settles
    -- (all-or-nothing). Allocations are single-use (consumed by
    -- `Allocation_ExecuteTransfer`); this choice is consuming, so a settlement
    -- runs at most once (idempotency via `intentId`).
    choice SwapSettlement_Settle : TextMap Allocation_ExecuteTransferResult
      with
        legAllocations : TextMap (ContractId Allocation, ContractId LegAuth, ExtraArgs)
          -- ^ One entry per leg: the funded allocation, that leg's `LegAuth`, and
          -- the registry choice context (obtained off-ledger from the wallet).
      controller executor
      do
        now <- getTime
        assertMsg "settlement deadline has not passed" (now < deadline)

        -- On-ledger economic bound enforcement (SPEC Â§6 step 3).
        let delivered = deliveredTo taker wantInstrument legs
        let spent = spentBy taker giveInstrument legs
        assertMsg "conservation: give-legs must sum to giveAmount" (spent == giveAmount)
        assertMsg "delivered must meet minReceive floor" (delivered >= minReceive)
        assertMsg
          "delivered must satisfy maxSlippageBps vs reference"
          (delivered >= slippageFloor referenceReceive maxSlippageBps)

        -- Execute every leg atomically via its per-leg authorization. The
        -- allocation MUST match the expected leg exactly (amount/asset/parties),
        -- and the `LegAuth` is what supplies the parties' authority.
        results <- forA (TextMap.toList (expectedAllocationsOf this)) $ \(legId, expectedSpec) -> do
          (allocCid, legAuthCid, extraArgs) <- case TextMap.lookup legId legAllocations of
            Some x -> pure x
            None -> abort ("missing allocation for leg " <> legId)
          alloc <- fetch @Allocation allocCid
          assertMsg
            ("allocation does not match expected leg " <> legId)
            ((view alloc).allocation == expectedSpec)
          res <- exercise legAuthCid (LegAuth_Execute with allocCid, extraArgs)
          pure (legId, res)
        pure (TextMap.fromList results)

    -- | Cancel the settlement, releasing every supplied allocation (funds return
    -- to the senders) via each leg's `LegAuth`. Used when a route is abandoned.
    choice SwapSettlement_Cancel : TextMap Allocation_CancelResult
      with
        legAllocations : TextMap (ContractId Allocation, ContractId LegAuth, ExtraArgs)
      controller executor
      do
        results <- forA (TextMap.toList legAllocations) $ \(legId, (allocCid, legAuthCid, extraArgs)) -> do
          res <- exercise legAuthCid (LegAuth_Cancel with allocCid, extraArgs)
          pure (legId, res)
        pure (TextMap.fromList results)

-- | The CIP-0056 settlement descriptor shared by every leg's allocation.
settlementInfoOf : SwapSettlement -> SettlementInfo
settlementInfoOf s = SettlementInfo with
  executor = s.executor
  settlementRef = Reference with id = s.intentId, cid = None
  requestedAt = s.createdAt
  allocateBefore = s.prepareUntil
  settleBefore = s.deadline
  meta = emptyMetadata

-- | The allocation each leg's sender is expected to have created.
expectedAllocationsOf : SwapSettlement -> TextMap AllocationSpecification
expectedAllocationsOf s = TextMap.fromList
  [ ( legId
    , AllocationSpecification with
        settlement = settlementInfoOf s
        transferLegId = legId
        transferLeg = toTransferLeg leg
    )
  | (legId, leg) <- TextMap.toList s.legs
  ]
